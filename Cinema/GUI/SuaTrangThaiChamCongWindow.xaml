<Window x:Class="Cinema.GUI.SuaTrangThaiChamCongWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sửa trạng thái chấm công"
        Height="520"
        Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Cập nhật trạng thái chấm công"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   FontSize="18"
                   FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBlock Text="Nhân viên"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="txtNhanVien"
                     Height="34"
                     IsReadOnly="True"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Text="Ca làm"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="txtCaLam"
                     Height="34"
                     IsReadOnly="True"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock Text="Ngày"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="txtNgay"
                     Height="34"
                     IsReadOnly="True"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,10,0,0">
            <TextBlock Text="Giờ vào"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="txtGioVao"
                     Height="34"
                     IsReadOnly="True"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,10,0,0">
            <TextBlock Text="Giờ ra"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="txtGioRa"
                     Height="34"
                     IsReadOnly="True"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Margin="0,10,0,0">
            <TextBlock Text="Trạng thái"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,6"/>
            <ComboBox x:Name="cbTrangThai"
                      Height="36"/>
        </StackPanel>

        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Đóng"
                    Width="92"
                    Height="36"
                    Margin="0,0,8,0"
                    Click="btnDong_Click"/>
            <Button Content="Lưu"
                    Width="92"
                    Height="36"
                    Click="btnLuu_Click"/>
        </StackPanel>
    </Grid>
</Window>
