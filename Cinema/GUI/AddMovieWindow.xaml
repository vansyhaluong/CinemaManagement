<Window x:Class="Cinema.GUI.AddMovieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cinema.GUI"
        WindowStartupLocation="CenterScreen"
        
        mc:Ignorable="d"
        Title="Thêm Phim Mới" Height="600" Width="1000">
    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#111827"
                CornerRadius="18"
                Padding="24">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="THÊM PHIM MỚI"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"/>

                    <TextBlock Text="Movie creation form"
                               Foreground="#94A3B8"
                               FontSize="14"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="🎬"
                           FontSize="34"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- BODY -->
        <Border Grid.Row="1"
                Margin="0,18,0,18"
                Background="#111827"
                CornerRadius="18"
                Padding="24">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- POSTER -->
                    <StackPanel Grid.Column="0">

                        <TextBlock Text="Poster"
               Foreground="#CBD5E1"
               FontWeight="SemiBold"
               Margin="0,0,0,10"/>

                        <Border Height="300"
            Background="#1E293B"
            CornerRadius="16">

                            <Grid>

                                <!-- Ảnh preview -->
                                <Image x:Name="imgPoster"
                   Stretch="UniformToFill"/>

                                <!-- Hiện khi chưa có ảnh -->
                                <StackPanel x:Name="txtNoImage"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                                    <TextBlock Text="🖼"
                           FontSize="42"
                           HorizontalAlignment="Center"/>

                                    <TextBlock Text="Chọn ảnh poster"
                           Foreground="#94A3B8"
                           Margin="0,10,0,0"/>
                                </StackPanel>

                            </Grid>
                        </Border>

                        <Button Content="Tải ảnh lên"
            Height="42"
            Margin="0,14,0,0"
            Background="#2563EB"
            Foreground="White"
            BorderThickness="0"
            Cursor="Hand"
            Click="btnUpLoad_Click"/>

                    </StackPanel>

                    <!-- FORM -->
                    <StackPanel Grid.Column="2">

                        <!-- Tiêu đề -->
                        <TextBlock Text="Tiêu đề"
                                   Foreground="#CBD5E1"
                                   Margin="0,0,0,6"/>

                        <TextBox Height="42"
                                 Background="#1E293B"
                                 Foreground="White"
                                 BorderThickness="0"
                                 Padding="12" x:Name="txtTitle"/>

                        <!-- Mô tả -->
                        <TextBlock Text="Mô tả"
                                   Foreground="#CBD5E1"
                                   Margin="0,16,0,6"/>

                        <TextBox Height="90"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#1E293B"
                                 Foreground="White"
                                 BorderThickness="0"
                                 Padding="12" x:Name="txtMoTa"/>

                        <!-- Row 1 -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Thời lượng (phút)"
                                           Foreground="#CBD5E1"
                                           Margin="0,0,0,6"/>

                                <TextBox Height="42"
                                         Background="#1E293B"
                                         Foreground="White"
                                         BorderThickness="0"
                                         Padding="12" x:Name="txtThoiLuong"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Ngày khởi chiếu"
                                           Foreground="#CBD5E1"
                                           Margin="0,0,0,6"/>

                                <DatePicker Height="42" Foreground="White" x:Name="dpNgayKhoiChieu"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 2 -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Quốc gia"
                                           Foreground="#CBD5E1"
                                           Margin="0,0,0,6"/>

                                <ComboBox Height="42" x:Name="cbQuocGia"
          Background="#1E293B"
          
          BorderThickness="0"
          Padding="10,4">

                                    <ComboBoxItem Content="Việt Nam"/>
                                    <ComboBoxItem Content="Hoa Kỳ"/>
                                    <ComboBoxItem Content="Hàn Quốc"/>
                                    <ComboBoxItem Content="Nhật Bản"/>
                                    <ComboBoxItem Content="Trung Quốc"/>
                                    <ComboBoxItem Content="Thái Lan"/>
                                    <ComboBoxItem Content="Ấn Độ"/>
                                    <ComboBoxItem Content="Pháp"/>
                                    <ComboBoxItem Content="Anh"/>
                                    <ComboBoxItem Content="Canada"/>
                                    <ComboBoxItem Content="Úc"/>

                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Trạng thái"
                                           Foreground="#CBD5E1"
                                           Margin="0,0,0,6"/>

                                <ComboBox Height="42" x:Name="cbTrangThai"
                                          Background="#1E293B"
                                          Foreground="White"
                                          BorderThickness="0">
                                    <ComboBoxItem Content="Đang chiếu"/>
                                    <ComboBoxItem Content="Sắp chiếu"/>
                                    <ComboBoxItem Content="Ngừng chiếu"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- Row 3 -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Suất chiếu"
                                           Foreground="#CBD5E1"
                                           Margin="0,0,0,6"/>

                                <ComboBox Height="42"
                                          Background="#1E293B" x:Name="cbSuatChieu"
                                          Foreground="White"
                                          BorderThickness="0">
                                    <ComboBoxItem Content="2D"/>
                                    <ComboBoxItem Content="3D"/>
                                    <ComboBoxItem Content="IMAX"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Thể loại"
                                           Foreground="#CBD5E1"
                                           Margin="0,0,0,6"/>

                                <ComboBox Height="42"
                                          Background="#1E293B" x:Name="cbTheLoai"
                                          Foreground="White"
                                          BorderThickness="0">
                                    <ComboBoxItem Content="Hành động"/>
                                    <ComboBoxItem Content="Kinh dị"/>
                                    <ComboBoxItem Content="Tình cảm"/>
                                    <ComboBoxItem Content="Hoạt hình"/>
                                    <ComboBoxItem Content="Phiêu lưu"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                    </StackPanel>

                </Grid>

            </ScrollViewer>

        </Border>

        <!-- FOOTER -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="Hủy"
                    Height="44"
                    Background="#334155"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>

            <Button Grid.Column="3"
                    Content="Lưu phim"
                    Height="44"
                    x:Name="btnSave"
                    Background="#2563EB"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand" Click="btnSave_Click"/>
        </Grid>

    </Grid>
</Window>
