<UserControl x:Class="Cinema.GUI.QuanLyPhongChieu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cinema.GUI"
             mc:Ignorable="d" 
             Background="{DynamicResource AppBackgroundBrush}"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20" >

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <DockPanel Margin="0,0,0,15">

            <TextBlock Text="QUẢN LÝ PHÒNG CHIẾU"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       
                       DockPanel.Dock="Left"/>

            <!-- ADD BUTTON -->
            <Button Content="+ Thêm phòng"
                    Width="140"
                    Height="38"
                    Background="#22C55E"
                    Foreground="White"
                    BorderThickness="0"
                    HorizontalAlignment="Right"
                    />

        </DockPanel>

        <!-- ================= LIST ================= -->


        <ItemsControl x:Name="icPhong"
                      Grid.Row="1"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Top">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>

                    <!-- CARD -->
                    <Border Width="260"
                            Height="120"
                            Background="White"
                            CornerRadius="14"
                            Margin="10"
                            Padding="15">

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10"
                                              Opacity="0.1"/>
                        </Border.Effect>

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- INFO -->
                            <StackPanel>

                                <TextBlock Text="{Binding TenPhong}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#111827"/>

                                <TextBlock Text="{Binding TenRap}"
                                           FontSize="13"
                                           Foreground="#6B7280"
                                           Margin="0,5,0,0"/>

                            </StackPanel>

                            <!-- ACTION -->
                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">

                                <Button Content="✏"
                                        Width="30"
                                        Height="30"
                                        Background="#3B82F6"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Margin="0,0,8,0"
                                        />

                                <Button Content="🗑"
                                        Width="30"
                                        Height="30"
                                        Background="#EF4444"
                                        Foreground="White"
                                        BorderThickness="0"
                                       />

                            </StackPanel>

                        </Grid>

                    </Border>

                </DataTemplate>
            </ItemsControl.ItemTemplate>

        </ItemsControl>



    </Grid>
</UserControl>
