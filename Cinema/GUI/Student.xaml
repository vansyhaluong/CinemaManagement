<UserControl x:Class="Cinema.GUI.Student"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Cinema.Controls"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1000">

    <Grid Background="{DynamicResource AppBackgroundBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="84"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="42"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">

            <Grid Margin="20,0">

                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Left">

                    <TextBlock Text="Employee Management"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <TextBlock Text="Manage cinema employees and accounts"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>

                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <Button Content="☀ / ☾ Toggle Theme"
                            Margin="0,0,16,0"
                            Click="ThemeToggle_Click"
                           />

                    <Button Content="🖨 Print"
                            Margin="0,0,8,0"/>

                    

                    <Button Content="+ Add Employee" Click="btnThem_Click"
                            Style="{StaticResource AccentButton}"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- STATISTICS -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">

            <StackPanel Orientation="Horizontal"
                        Margin="12,0"
                        VerticalAlignment="Center">

                <controls:StatCard CardLabel="Total Employees"
                                   x:Name="cardTotalEmployees"
                                   Value="0"
                                   SubLabel="All cinema branches"
                                   ValueBrushKey="TextPrimaryBrush"
                                   Margin="0,0,10,0"/>

                <controls:StatCard CardLabel="Working Today"
                                   x:Name="cardWorkingToday"
                                   Value="0"
                                   SubLabel="Current active staff"
                                   ValueBrushKey="SuccessBrush"
                                   Margin="0,0,10,0"/>

                <controls:StatCard CardLabel="Managers"
                                   x:Name="cardManagers"
                                   Value="0"
                                   SubLabel="Management accounts"
                                   ValueBrushKey="WarningBrush"
                                   Margin="0,0,10,0"/>

                <controls:StatCard CardLabel="Inactive"
                                   x:Name="cardInactive"
                                   Value="0"
                                   SubLabel="Disabled accounts"
                                   ValueBrushKey="DangerBrush"/>

            </StackPanel>

        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- FILTER -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="12,8"
                        VerticalAlignment="Center">

                <TextBox Width="220"
                         Margin="0,0,8,0"
                         x:Name="txtSearch"
                         Text="Search employee..."
                         TextChanged="txtSearch_TextChanged"
                         GotFocus="txtSearch_GotFocus"
                         LostFocus="txtSearch_LostFocus"/>

                <ComboBox Width="150"
                          Margin="0,0,8,0"
                          SelectedIndex="0"
                          x:Name="cmbRap"
                          DisplayMemberPath="TenRap"
                          SelectedValuePath="MaRap"
                          SelectionChanged="cmbRap_SelectionChanged"/>

                <ComboBox Width="140"
                          SelectedIndex="0"
                          x:Name="cmbStatus"
                          SelectionChanged="cmbStatus_SelectionChanged"/>

            </StackPanel>

            <!-- DATAGRID -->
            <DataGrid Grid.Row="1"
                      x:Name="dgvNhanVien"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      IsReadOnly="True"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      Background="{DynamicResource AppBackgroundBrush}"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      RowBackground="{DynamicResource AppBackgroundBrush}"
                      AlternatingRowBackground="{DynamicResource AppBackgroundBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}">

                <!-- HEADER STYLE -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">

                        <Setter Property="Background"
                                Value="{DynamicResource AppBackgroundBrush}"/>

                        <Setter Property="Foreground"
                                Value="{DynamicResource TextMutedBrush}"/>

                        <Setter Property="FontSize"
                                Value="11"/>

                        <Setter Property="Padding"
                                Value="12,8"/>

                        <Setter Property="BorderBrush"
                                Value="{DynamicResource BorderBrush}"/>

                        <Setter Property="BorderThickness"
                                Value="0,0,0,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>

                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <!-- COLUMNS -->
                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding MaNhanVien}"
                                        Width="70">

                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">

                                <Setter Property="FontFamily"
                                        Value="Consolas"/>

                                <Setter Property="FontSize"
                                        Value="12"/>

                                <Setter Property="Padding"
                                        Value="12,8"/>
                                <Setter Property="HorizontalAlignment" Value="Left"/>

                            </Style>
                        </DataGridTextColumn.ElementStyle>

                    </DataGridTextColumn>

                    <DataGridTextColumn Header="FULL NAME"
                                        Binding="{Binding HoTen}"
                                        Width="*"/>

                    <DataGridTextColumn Header="PHONE NUMBER"
                                        Binding="{Binding SoDienThoai}"
                                        Width="150"/>

                    <DataGridTextColumn Header="ACCOUNT ID"
                                        Binding="{Binding MaTaiKhoan}"
                                        Width="120"/>

                    <DataGridTextColumn Header="BRANCH ID"
                                        Binding="{Binding MaRap}"
                                        Width="100"/>

                    <DataGridTemplateColumn Header="ACTION"
                        Width="200">

                        <DataGridTemplateColumn.CellTemplate>

                            <DataTemplate>

                                <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left">

                                    <!-- EDIT BUTTON -->
                                    <Button Content="✏"
                        Width="30"
                        Height="30"
                        Click="btnSua_Click"    
                        Tag="{Binding}"
                        Margin="0,0,6,0"
                        
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="11"/>

                                    <!-- DELETE BUTTON -->
                                    <Button Content="🗑"
                        Width="30"
                        Height="30"
                        Click="btnXoa_Click"
                        Foreground="White"
                        BorderThickness="0"
                        Tag="{Binding}"
                        Cursor="Hand"
                        FontSize="11"/>

                                </StackPanel>

                            </DataTemplate>

                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>

        </Grid>

        <!-- BOTTOM -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">

            <Grid Margin="14,0">

                <TextBlock x:Name="lblPageInfo"
                           Text="Showing 10 of 24 employees"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <Button Content="‹"
                            Margin="0,0,4,0"
                            Width="28"
                            Height="26"
                            Padding="0"/>

                    <Button Content="1"
                            Margin="0,0,4,0"
                            Width="28"
                            Height="26"
                            Padding="0"/>

                    <Button Content="2"
                            Margin="0,0,4,0"
                            Width="28"
                            Height="26"
                            Padding="0"/>

                    <Button Content="3"
                            Margin="0,0,4,0"
                            Width="28"
                            Height="26"
                            Padding="0"/>

                    <Button Content="›"
                            Width="28"
                            Height="26"
                            Padding="0"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</UserControl>
