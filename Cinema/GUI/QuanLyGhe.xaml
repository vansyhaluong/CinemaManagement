<UserControl x:Class="Cinema.GUI.QuanLyGhe"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Cinema.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1200">

    <Grid Background="{DynamicResource AppBackgroundBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="84"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="42"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">

            <Grid Margin="20,0">

                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Left">

                    <TextBlock Text="Seat Management"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <TextBlock Text="Manage cinema seats and seat status"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>

                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <Button Content="☀ / ☾ Toggle Theme"
                            Margin="0,0,16,0"
                            />

                    <Button Content="🖨 Print"
                            Margin="0,0,8,0"/>

                    <Button Content="⬇ Export"
                            Margin="0,0,8,0"/>

                    <Button Content="+ Add Seat"
                            Style="{StaticResource AccentButton}"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- STATISTICS -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">

            <StackPanel Orientation="Horizontal"
                        Margin="12,0"
                        VerticalAlignment="Center">

                <controls:StatCard CardLabel="Total Seats"
                                   Value="250"
                                   SubLabel="All cinema rooms"
                                   ValueBrushKey="TextPrimaryBrush"
                                   Margin="0,0,10,0"/>

                <controls:StatCard CardLabel="Available"
                                   Value="220"
                                   SubLabel="Ready for booking"
                                   ValueBrushKey="SuccessBrush"
                                   Margin="0,0,10,0"/>

                <controls:StatCard CardLabel="Reserved"
                                   Value="18"
                                   SubLabel="Currently booked"
                                   ValueBrushKey="WarningBrush"
                                   Margin="0,0,10,0"/>

                <controls:StatCard CardLabel="Maintenance"
                                   Value="12"
                                   SubLabel="Unavailable seats"
                                   ValueBrushKey="DangerBrush"/>

            </StackPanel>

        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- FILTER BAR -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="12,8"
                        VerticalAlignment="Center">

                <TextBox Width="220"
                         Margin="0,0,8,0"
                         x:Name="txtSearch"
                         Text="Search seat..."/>

                <ComboBox Width="140"
                          Margin="0,0,8,0"
                          SelectedIndex="0"
                          x:Name="cmbPhong">

                    <ComboBoxItem>All Rooms</ComboBoxItem>
                    <ComboBoxItem>Room 1</ComboBoxItem>
                    <ComboBoxItem>Room 2</ComboBoxItem>
                    <ComboBoxItem>Room 3</ComboBoxItem>

                </ComboBox>

                <ComboBox Width="140"
                          SelectedIndex="0"
                          x:Name="cmbTrangThai">

                    <ComboBoxItem>All Status</ComboBoxItem>
                    <ComboBoxItem>Available</ComboBoxItem>
                    <ComboBoxItem>Reserved</ComboBoxItem>
                    <ComboBoxItem>Maintenance</ComboBoxItem>

                </ComboBox>

            </StackPanel>

            <!-- DATAGRID -->
            <DataGrid Grid.Row="1"
                      x:Name="dgvSeats"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      IsReadOnly="True"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      Background="{DynamicResource AppBackgroundBrush}"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      RowBackground="{DynamicResource AppBackgroundBrush}"
                      AlternatingRowBackground="{DynamicResource AppBackgroundBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">

                        <Setter Property="Background"
                                Value="{DynamicResource AppBackgroundBrush}"/>

                        <Setter Property="Foreground"
                                Value="{DynamicResource TextMutedBrush}"/>

                        <Setter Property="FontSize"
                                Value="11"/>

                        <Setter Property="Padding"
                                Value="12,8"/>

                        <Setter Property="BorderBrush"
                                Value="{DynamicResource BorderBrush}"/>

                        <Setter Property="BorderThickness"
                                Value="0,0,0,1"/>

                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding MaGhe}"
                                        
                                        Width="100">

                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">

                                <Setter Property="FontFamily"
                                        Value="Consolas"/>

                                <Setter Property="FontSize"
                                        Value="12"/>

                                <Setter Property="Padding"
                                        Value="12,8"/>

                            </Style>
                        </DataGridTextColumn.ElementStyle>

                    </DataGridTextColumn>

                    <DataGridTextColumn Header="SEAT CODE"
                                        Binding="{Binding TenGhe}"
                                        Width="120"/>

                    <DataGridTextColumn Header="ROOM"
                                        Binding="{Binding TenPhong}"
                                        Width="120"/>

                    <DataGridTextColumn Header="ROW"
                                        Binding="{Binding DayGhe}"
                                        Width="80"/>

                    <DataGridTextColumn Header="TYPE"
                                        Binding="{Binding LoaiGhe}"
                                        Width="120"/>

                    <DataGridTextColumn Header="PRICE"
                                        Binding="{Binding GiaDisplay}"
                                        Width="100">

                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">

                                <Setter Property="FontFamily"
                                        Value="Consolas"/>

                                <Setter Property="FontSize"
                                        Value="12"/>

                                <Setter Property="Padding"
                                        Value="12,8"/>

                            </Style>
                        </DataGridTextColumn.ElementStyle>

                    </DataGridTextColumn>

                    <DataGridTextColumn Header="STATUS"
                                        Binding="{Binding TrangThai}"
                                        Width="120"/>

                </DataGrid.Columns>

            </DataGrid>

        </Grid>

        <!-- BOTTOM BAR -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">

            <Grid Margin="14,0">

                <TextBlock x:Name="lblPageInfo"
                           Text="Showing 10 of 250 seats"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <Button Content="‹"
                            Margin="0,0,4,0"
                            Width="28"
                            Height="26"
                            Padding="0"/>

                    <Button Content="1"
                            Margin="0,0,4,0"
                            Width="28"
                            Height="26"
                            Padding="0"/>

                    <Button Content="2"
                            Margin="0,0,4,0"
                            Width="28"
                            Height="26"
                            Padding="0"/>

                    <Button Content="3"
                            Margin="0,0,4,0"
                            Width="28"
                            Height="26"
                            Padding="0"/>

                    <Button Content="›"
                            Width="28"
                            Height="26"
                            Padding="0"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</UserControl>
