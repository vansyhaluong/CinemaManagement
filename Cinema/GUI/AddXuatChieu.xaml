<Window x:Class="Cinema.GUI.AddXuatChieu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cinema.GUI"
        mc:Ignorable="d"
         Title="Thêm suất chiếu"
 Width="860"
 Height="520"
 WindowStartupLocation="CenterScreen"
 ResizeMode="NoResize"
 WindowStyle="None"
 xmlns:controls="clr-namespace:Cinema.Controls"
 AllowsTransparency="True">
    <Window.Resources>

        <!-- COLORS -->
        <SolidColorBrush x:Key="MainColor" Color="#0F1923"/>
        <SolidColorBrush x:Key="AccentColor" Color="#2563EB"/>
        <SolidColorBrush x:Key="BorderColor" Color="#D9E0E7"/>
        <SolidColorBrush x:Key="GrayText" Color="#6B7280"/>

        <!-- TEXTBOX -->
        <!--<Style TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>-->

        <!-- COMBOBOX -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            
        </Style>

        <!-- DATEPICKER -->
        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- BUTTON -->
        <Style TargetType="Button" x:Key="MainButton">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border 
         CornerRadius="18"
         Margin="8">

        <Grid Background="{DynamicResource AppBackgroundBrush}"
           >

            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                 
                 Background="{StaticResource MainColor}"
                 CornerRadius="18,18,0,0">

                <Grid Margin="20,0"
                   >

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="THÊM SUẤT CHIẾU"
                                FontSize="24"
                                FontWeight="Bold"
                                Foreground="White"/>

                        <TextBlock Text="Tạo lịch chiếu phim mới"
                                Foreground="#C7D0DB"
                                FontSize="13"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                         Width="34"
                         Height="34"
                         Background="Transparent"
                         Foreground="White"
                         FontSize="18"
                         BorderThickness="0"
                         Content="✕"/>
                </Grid>
            </Border>

            <!-- BODY -->
            <Grid Grid.Row="1"
      Margin="28">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT -->
                <StackPanel Grid.Column="0">

                    <!-- PHIM -->
                    <TextBlock Text="Phim"
                   FontSize="12"
                   Margin="0,0,0,6"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontWeight="SemiBold"/>

                    <ComboBox x:Name="cbPhim"
                              SelectionChanged="cbPhim_SelectionChanged"
                  DisplayMemberPath="TieuDe"
                   FontSize="12"
                  SelectedValuePath="MaPhim"/>

                    <!-- RẠP -->
                    <TextBlock Text="Rạp chiếu"
                   FontSize="12"
                   Margin="0,18,0,6"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontWeight="SemiBold"/>

                    <ComboBox x:Name="cbRap"
                  
                  SelectionChanged="cbRap_SelectionChanged"/>

                    <!-- PHÒNG -->
                    <TextBlock Text="Phòng chiếu"
                   FontSize="12"
                   Margin="0,18,0,6"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontWeight="SemiBold"/>

                    <ComboBox x:Name="cbPhong"
                  DisplayMemberPath="TenPhong"
                              FontSize="12"
                  SelectedValuePath="MaPhong"/>

                    <!-- NGÀY -->
                    <TextBlock Text="Ngày chiếu"
                   FontSize="12"
                   Margin="0,18,0,6"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontWeight="SemiBold"/>

                    <DatePicker x:Name="dpNgay"
                                SelectedDateChanged="OnChange"/>

                </StackPanel>

                <!-- RIGHT -->
                <StackPanel Grid.Column="2">

                    <!-- GIỜ BẮT ĐẦU -->
                    <TextBlock Text="Giờ bắt đầu"
                   FontSize="12"
                   Margin="0,0,0,6"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontWeight="SemiBold"/>

                    <ComboBox x:Name="cbGio"
          SelectionChanged="OnChange">
                    </ComboBox>

                    <!-- GIỜ KẾT THÚC -->
                    <TextBlock Text="Giờ kết thúc"
                   FontSize="12"
                   Margin="0,18,0,6"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontWeight="SemiBold"/>

                    <TextBox x:Name="txtGioKetThuc"
                 Height="32"
                 FontSize="12"
                 Foreground="White"
                 Padding="10,0"
                 IsReadOnly="True"/>

                    <!-- GHI CHÚ -->
                    <TextBlock Text="* Giờ kết thúc sẽ tự động tính theo thời lượng phim"
                   Margin="0,12,0,0"
                   FontSize="12"
                   Foreground="#22C55E"/>

                </StackPanel>

            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="2"
                 
                 CornerRadius="0,0,18,18">

                <StackPanel Orientation="Horizontal"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         Margin="0,0,24,0">

                    <Button Width="100"
                         Margin="0,0,10,0"
                         Background="#9CA3AF"
                         FontSize="12"
                            Click="btnCancel_Click"
                         Style="{StaticResource MainButton}"
                         Content="Hủy"/>

                    <Button Width="100"
                         Background="{StaticResource AccentColor}"
                         Style="{StaticResource AccentButton}"
                         FontSize="12"
                            x:Name="btnSave"
                         Click="btnSave_Click"
                         Content="Lưu"/>

                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
