<UserControl x:Class="Cinema.GUI.QuanLySuatChieu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cinema.GUI"
             xmlns:controls="clr-namespace:Cinema.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>

        <!-- MAIN COLORS -->
        <SolidColorBrush x:Key="MainColor" Color="#0F1923"/>
        <SolidColorBrush x:Key="MainLight" Color="#1D2A36"/>
        <SolidColorBrush x:Key="AccentColor" Color="#3FA9F5"/>
        <SolidColorBrush x:Key="WhiteColor" Color="White"/>
        <SolidColorBrush x:Key="BorderColor" Color="#DCE2E8"/>
        <SolidColorBrush x:Key="TextGray" Color="#6B7280"/>

        <!-- CARD -->
        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- BUTTON -->
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource MainColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ICON BUTTON -->
        <Style TargetType="Button" x:Key="IconButton">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="{StaticResource MainColor}"
                CornerRadius="22"
                Padding="28"
                Margin="0,0,0,18">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="QUẢN LÝ SUẤT CHIẾU"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Theo dõi lịch chiếu phim, chỉnh sửa và quản lý suất chiếu"
                               Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="#BFC8D4"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Width="120"
                        
                        Click="btnThem_Click"
                        Style="{StaticResource PrimaryButton}"
                        Background="{StaticResource AccentColor}"
                        Content="+ Thêm suất chiếu"/>
            </Grid>
        </Border>

        <!-- FILTER -->
        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}">

            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <DatePicker Height="42"
                            x:Name="dtNgayChieu"
                            SelectedDateChanged="dpNgayChieu_SelectedDateChanged"
                            FontSize="14"/>

                <ComboBox Grid.Column="1"
                          Margin="14,0,0,0"
                          Height="42"
                          FontSize="14"
                          x:Name="cbPhim"
                          SelectionChanged="cbPhim_SelectionChanged"
                          >
                    <!--<ComboBoxItem Content="Tất cả phim"/>
                    <ComboBoxItem Content="Avengers Endgame"/>
                    <ComboBoxItem Content="Spider Man"/>-->
                </ComboBox>

                

                <TextBlock Grid.Column="3"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{StaticResource TextGray}"
                           Text=""/>
            </Grid>
        </Border>

        <!-- TABLE -->
        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}">

            <DataGrid AutoGenerateColumns="False"
          HeadersVisibility="Column"
          CanUserAddRows="False"
          IsReadOnly="True"
          x:Name="dgSuatChieu"
          GridLinesVisibility="Horizontal"
          RowHeight="52"
          FontSize="14"
          BorderThickness="0"
          Background="White"
          AlternatingRowBackground="#F8FAFC"
          RowBackground="White"
          HorizontalContentAlignment="Center"
          VerticalContentAlignment="Center">

                <!-- HEADER -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F3F6F9"/>
                        <Setter Property="Foreground" Value="{StaticResource MainColor}"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Height" Value="48"/>
                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="FontSize" Value="14"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <!-- CELL STYLE -->
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>

                    <!-- BỎ CỘT MÃ -->

                    <DataGridTextColumn Header="Tên phim"
                            Width="300"
                            Binding="{Binding MaPhimNavigation.TieuDe}"/>

                    <DataGridTextColumn Header="Phòng"
                            Width="120"
                            Binding="{Binding MaPhongNavigation.TenPhong}"/>

                    <DataGridTextColumn Header="Bắt đầu"
                            Width="190"
                            Binding="{Binding ThoiGianBatDau, StringFormat=dd/MM/yyyy HH:mm}"/>

                    <DataGridTextColumn Header="Kết thúc"
                            Width="190"
                            Binding="{Binding ThoiGianKetThuc, StringFormat=dd/MM/yyyy HH:mm}"/>

                    <DataGridTemplateColumn Header="Thao tác"
                                Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                                    <Button Style="{StaticResource IconButton}"
                                Click="btnSua_Click"
                                Tag="{Binding}"
                                Background="#2563EB"
                                Content="✎"/>

                                    <Button Style="{StaticResource IconButton}"
                                Background="#DC2626"
                                Tag="{Binding}"
                                Click="btnXoa_Click"
                                Content="🗑"/>

                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>
</UserControl>
