<Window x:Class="Cinema.GUI.SuaThuongPhatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sửa thưởng / kỷ luật"
        Height="430"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F172A">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Cập nhật thưởng / kỷ luật"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock Text="Loại"
                       Foreground="#CBD5E1"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="txtLoai"
                     Height="36"
                     IsReadOnly="True"
                     Background="#111827"
                     Foreground="#E5E7EB"
                     BorderBrush="#334155"
                     BorderThickness="1"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="Nhân viên"
                       Foreground="#CBD5E1"
                       Margin="0,0,0,6"/>
            <ComboBox x:Name="cbNhanVien"
                      Height="36"
                      Background="#111827"
                      Foreground="#E5E7EB"
                      BorderBrush="#334155"
                      BorderThickness="1"
                      DisplayMemberPath="HoTen"
                      SelectedValuePath="MaNhanVien"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock Text="Ngày"
                       Foreground="#CBD5E1"
                       Margin="0,0,0,6"/>
            <DatePicker x:Name="dpNgay"
                        Height="36"
                        Background="#111827"
                        Foreground="#E5E7EB"
                        BorderBrush="#334155"
                        BorderThickness="1"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <TextBlock Text="Số tiền"
                       Foreground="#CBD5E1"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="txtSoTien"
                     Height="36"
                     Background="#111827"
                     Foreground="#E5E7EB"
                     BorderBrush="#334155"
                     BorderThickness="1"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,12,0,0">
            <TextBlock Text="Lý do"
                       Foreground="#CBD5E1"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="txtLyDo"
                     Height="120"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Background="#111827"
                     Foreground="#E5E7EB"
                     BorderBrush="#334155"
                     BorderThickness="1"/>
        </StackPanel>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button x:Name="btnDong"
                    Content="Đóng"
                    Width="100"
                    Height="38"
                    Margin="0,0,10,0"
                    Background="#1E293B"
                    Foreground="#E5E7EB"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    Click="btnDong_Click"/>
            <Button x:Name="btnLuu"
                    Content="Lưu"
                    Width="100"
                    Height="38"
                    Background="#2563EB"
                    Foreground="White"
                    BorderThickness="0"
                    Click="btnLuu_Click"/>
        </StackPanel>
    </Grid>
</Window>
