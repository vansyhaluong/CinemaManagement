<Window x:Class="Cinema.GUI.ThemSanPham"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cinema.GUI"
        mc:Ignorable="d"
        Title="Thêm sản phẩm"
        Width="420"
        Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Thêm sản phẩm"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,18"/>

        <TextBlock Grid.Row="1" Text="Tên sản phẩm"
                   Foreground="{DynamicResource TextMutedBrush}"/>

        <TextBox Grid.Row="2"
                 x:Name="txtTen"
                 Height="34"
                 Margin="0,6,0,12"/>

        <TextBlock Grid.Row="3" Text="Giá bán"
                   Foreground="{DynamicResource TextMutedBrush}"/>

        <TextBox Grid.Row="4"
                 x:Name="txtGia"
                 Height="34"
                 Margin="0,6,0,12"/>

        <TextBlock Grid.Row="5" Text="Loại sản phẩm"
                   Foreground="{DynamicResource TextMutedBrush}"/>

        <ComboBox Grid.Row="6"
                  x:Name="cbLoaiSanPham"
                  Height="34"
                  DisplayMemberPath="TenLoai"
                  SelectedValuePath="MaLoaiSp"
                  Margin="0,6,0,12"/>

        <StackPanel Grid.Row="7">
            <TextBlock Text="Hình ảnh sản phẩm"
               Foreground="{DynamicResource TextMutedBrush}"/>

            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="95"
                Height="95"
                Background="White"
                CornerRadius="10"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
                    <Image x:Name="imgPreview"
                   Stretch="Uniform"
                   Margin="6"/>
                </Border>

                <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0">
                    <!--<TextBox x:Name="txtHinhAnh"
                     Height="34"
                     IsReadOnly="True"
                     Text="/Images/no-image.png"
                     Margin="0,0,0,8"/>-->

                    <Button Content="Chọn ảnh"
                    Width="100"
                    Height="32"
                    HorizontalAlignment="Left"
                    Click="BtnChonAnh_Click"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Hủy"
                    Width="80"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="BtnHuy_Click"/>

            <Button Content="Lưu"
                    Width="90"
                    Height="34"
                    Style="{StaticResource AccentButton}"
                    Click="BtnLuu_Click"/>
        </StackPanel>
    </Grid>
</Window>
