<UserControl x:Class="Cinema.GUI.Main"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cinema.GUI"
             xmlns:conv="clr-namespace:Cinema.GUI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <conv:ImageConverter x:Key="ImageConverter"/>
    </UserControl.Resources>
    <Grid Background="{DynamicResource AppBackgroundBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Border Background="#111827" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎬"
                               FontSize="28"
                               VerticalAlignment="Center" Foreground="White"/>
                    <TextBlock Text="DANH SÁCH PHIM"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="MOVIE MANAGEMENT SYSTEM"
                           Foreground="#9CA3AF"
                           FontSize="16"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ================= FILTER BAR ================= -->
        <Grid Grid.Row="1" Margin="20,10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <!-- Genre -->
            <ComboBox x:Name="cbTheLoai"
                      Grid.Column="0"
                      Height="40"
                      Margin="5"
                      Padding="8"
                      SelectedIndex="0"
                      SelectionChanged="Filter_SelectionChanged"/>

            <!-- Country -->
            <ComboBox x:Name="cbQuocGia"
                      Grid.Column="1"
                      Height="40"
                      Margin="5"
                      Padding="8"
                      SelectedIndex="0"
                      SelectionChanged="Filter_SelectionChanged"/>

            <!-- Search -->
            <TextBox x:Name="txtTimKiem"
                     Grid.Column="2"
                     Height="40"
                     Margin="5"
                     Padding="10"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     Foreground="#94A3B8"
                     Text="Tìm kiếm phim..."
                     TextChanged="txtTimKiem_TextChanged"
                     GotFocus="txtTimKiem_GotFocus"
                     LostFocus="txtTimKiem_LostFocus"/>

            <!-- Add -->
            <Button Grid.Column="3"
                    x:Name="btnThemPhim"
                    Content="+ Add Movie"
                    Background="#2563EB"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="5"
                    Click="btnThemPhim_Click"/>
        </Grid>

        <!-- ================= MOVIE GRID ================= -->
        <ScrollViewer Grid.Row="2"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
              Margin="10">
            <ItemsControl Grid.Row="2"
              x:Name="icPhim"
              ItemsSource="{Binding Phim}"
              Margin="20">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <!-- CARD -->
                        <Border Width="220"
                    Height="340"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="18"
                    Margin="10"
                    ClipToBounds="True">

                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="RenderTransformOrigin"
                                Value="0.5,0.5"/>

                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Setter.Value>
                                    </Setter>

                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="22"
                                                  ShadowDepth="0"
                                                  Opacity="0.28"
                                                  Color="Black"/>
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1.025"
                                                        ScaleY="1.025"/>
                                                </Setter.Value>
                                            </Setter>

                                            <Setter Property="BorderBrush"
                                        Value="#EF4444"/>

                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="32"
                                                          ShadowDepth="0"
                                                          Opacity="0.45"
                                                          Color="Black"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid Cursor="Hand"
                      MouseLeftButtonDown="Poster_Click">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="260"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- POSTER AREA -->
                                <Grid Grid.Row="0">

                                    <Image Source="{Binding AnhBia, Converter={StaticResource ImageConverter}}"
                               Stretch="UniformToFill"/>

                                    <!-- Gradient bottom overlay -->
                                    <Border VerticalAlignment="Bottom"
                                Height="90">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="0,1">
                                                <GradientStop Color="#00000000"
                                                  Offset="0"/>
                                                <GradientStop Color="#E6111827"
                                                  Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <!-- Top badge -->
                                    <Border HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="10"
                                Padding="7,3"
                                CornerRadius="8"
                                Background="#EF4444">
                                        <TextBlock Text="New"
                                       Foreground="White"
                                       FontSize="10"
                                       FontWeight="Bold"/>
                                    </Border>

                                </Grid>

                                <!-- INFO AREA -->
                                <Grid Grid.Row="1"
                          Margin="12,10,12,12">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                   Text="{Binding TieuDe}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxHeight="40"/>

                                    <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Bottom">

                                        <Border Background="#F59E0B"
                                    CornerRadius="6"
                                    Padding="6,2">
                                            <TextBlock Text="Cinema"
                                           Foreground="#111827"
                                           FontSize="10"
                                           FontWeight="Bold"/>
                                        </Border>

                                        <TextBlock Text="  •  Chi tiết"
                                       Foreground="#9CA3AF"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
         <!--POPUP MOVIE DETAIL-->
        <Grid x:Name="PopupContainer"
      Visibility="Collapsed"
      Background="#B0000000"
      Grid.RowSpan="3"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch"
      Panel.ZIndex="999">

            <Border Width="820"
            Height="430"
            CornerRadius="24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            ClipToBounds="True">

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#18181B" Offset="0"/>
                        <GradientStop Color="#111827" Offset="0.55"/>
                        <GradientStop Color="#450A0A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Poster -->
                    <Border Grid.Column="0"
                    Margin="22"
                    CornerRadius="18"
                    ClipToBounds="True">
                        <Image x:Name="imgPoster"
                       Stretch="UniformToFill"/>
                    </Border>

                    <!-- Content -->
                    <Grid Grid.Column="1"
                  Margin="10,24,24,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Close -->
                        <Button Content="✕"
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="#33FFFFFF"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="ClosePopup_Click"/>

                        <!-- Title -->
                        <StackPanel Grid.Row="0"
                            Margin="0,4,48,0">
                            <TextBlock x:Name="txtTitle"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"
                               TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal"
                                Margin="0,12,0,0">
                                <Border Background="#E50914"
                                CornerRadius="10"
                                Padding="10,4"
                                Margin="0,0,8,0">
                                    <TextBlock Text="NOW SHOWING"
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="Bold"/>
                                </Border>

                                <Border Background="#22C55E22"
                                CornerRadius="10"
                                Padding="10,4">
                                    <TextBlock x:Name="txtStatus"
                                       Foreground="#22C55E"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- Info badges -->
                        <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Margin="0,18,0,14">
                            <Border Background="#1F2937"
                            CornerRadius="12"
                            Padding="12,8"
                            Margin="0,0,10,0">
                                <TextBlock x:Name="txtGenre"
                                   Foreground="#D1D5DB"
                                   FontSize="13"/>
                            </Border>

                            <Border Background="#1F2937"
                            CornerRadius="12"
                            Padding="12,8"
                            Margin="0,0,10,0">
                                <TextBlock x:Name="txtCountry"
                                   Foreground="#D1D5DB"
                                   FontSize="13"/>
                            </Border>

                            <Border Background="#1F2937"
                            CornerRadius="12"
                            Padding="12,8">
                                <TextBlock x:Name="txtDuration"
                                   Foreground="#D1D5DB"
                                   FontSize="13"/>
                            </Border>
                        </StackPanel>

                        <!-- Description -->
                        <Border Grid.Row="2"
                        Background="#22FFFFFF"
                        CornerRadius="16"
                        Padding="16"
                        Margin="0,0,0,18">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="txtDescription"
                                   Foreground="#E5E7EB"
                                   FontSize="14"
                                   LineHeight="22"
                                   TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>

                        <!-- Buttons -->
                        <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                            <Button Content="Đóng"
                            Width="100"
                            Height="40"
                            Margin="0,0,10,0"
                            Background="#374151"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="ClosePopup_Click"/>

                            <Button Content="🎟 Đặt vé"
                            Width="130"
                            Height="40"
                            Background="#E50914"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnDatVe_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
