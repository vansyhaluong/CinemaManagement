<UserControl x:Class="Cinema.GUI.Main"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cinema.GUI"
             xmlns:conv="clr-namespace:Cinema.GUI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <conv:ImageConverter x:Key="ImageConverter"/>
    </UserControl.Resources>
    <Grid Background="{DynamicResource AppBackgroundBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Border Background="#111827" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎬"
                               FontSize="28"
                               VerticalAlignment="Center" Foreground="White"/>
                    <TextBlock Text="CGV CINEMA"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="MOVIE MANAGEMENT SYSTEM"
                           Foreground="#9CA3AF"
                           FontSize="16"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ================= FILTER BAR ================= -->
        <Grid Grid.Row="1" Margin="20,10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <!-- Genre -->
            <ComboBox Grid.Column="0"
                      Height="40"
                      Margin="5"
                      Padding="8"
                      SelectedIndex="0">
                <ComboBoxItem Content="All Genres"/>
                <ComboBoxItem Content="Action"/>
                <ComboBoxItem Content="Comedy"/>
                <ComboBoxItem Content="Horror"/>
                <ComboBoxItem Content="Romance"/>
            </ComboBox>

            <!-- Country -->
            <ComboBox Grid.Column="1"
                      Height="40"
                      Margin="5"
                      Padding="8"
                      SelectedIndex="0">
                <ComboBoxItem Content="All Countries"/>
                <ComboBoxItem Content="USA"/>
                <ComboBoxItem Content="Korea"/>
                <ComboBoxItem Content="Japan"/>
                <ComboBoxItem Content="Vietnam"/>
            </ComboBox>

            <!-- Search -->
            <TextBox Grid.Column="2"
                     Height="40"
                     Margin="5"
                     Padding="10"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     Text="Search movie..." />

            <!-- Add -->
            <Button Grid.Column="3"
                    Content="+ Add Movie"
                    Background="#2563EB"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="5"/>
        </Grid>

        <!-- ================= MOVIE GRID ================= -->
        <ScrollViewer Grid.Row="2"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
              Margin="10">
            <ItemsControl Grid.Row="2"
                      x:Name="icPhim"
                     ItemsSource="{Binding Phim}"
                      Margin="20">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <!-- CARD -->
                        <Border Width="210"
                            Height="270"
                            Background="White"
                            CornerRadius="14"
                            Margin="10"
                            >

                            <Border.Style>
                                <Style TargetType="Border">

                                    <!-- Shadow -->
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="15"
                                                          ShadowDepth="2"
                                                          Opacity="0.12"
                                                          Color="Black"/>
                                        </Setter.Value>
                                    </Setter>

                                    <!-- Hover -->
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                </Setter.Value>
                                            </Setter>

                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="25"
                                                                  ShadowDepth="4"
                                                                  Opacity="0.25"
                                                                  Color="Black"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>

                                </Style>
                            </Border.Style>

                            <Border.RenderTransformOrigin>
                                <Point X="0.5" Y="0.5"/>
                            </Border.RenderTransformOrigin>

                            <Grid>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="210"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- POSTER -->
                                <Grid Cursor="Hand"
MouseLeftButtonDown="Poster_Click">

                                    <Border CornerRadius="14,14,0,0"
                                        >
                                        <Image Source="{Binding AnhBia, Converter={StaticResource ImageConverter}}"
                                           Stretch="Fill"
                                           />
                                    </Border>

                                    <!-- dark overlay -->
                                    <Border CornerRadius="14,14,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00000000" Offset="0.5"/>
                                                <GradientStop Color="#CC000000" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <!-- status -->
                                    <!--<Border Background="#10B981"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="10"
                                        Padding="6,2"
                                        CornerRadius="6">

                                        <TextBlock Text="{Binding Status}"
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="Bold"/>
                                    </Border>-->

                                </Grid>

                                <!-- INFO -->
                                <StackPanel Grid.Row="1" Margin="10">

                                    <TextBlock Text="{Binding TieuDe}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           Foreground="#111827"/>

                                    <!--<TextBlock Text="{Binding Genre}"
                                           FontSize="12"
                                           Foreground="#6B7280"/>

                                <TextBlock Text="{Binding Country}"
                                           FontSize="12"
                                           Foreground="#6B7280"/>

                                <TextBlock Text="{Binding Duration}"
                                           FontSize="12"
                                           Foreground="#6B7280"/>

                                <Button Content="View Details"
                                        Height="28"
                                        Margin="0,8,0,0"
                                        Background="#2563EB"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"/>-->

                                </StackPanel>

                            </Grid>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </ScrollViewer>
        <Grid x:Name="PopupContainer"
      Visibility="Collapsed"
      Background="#80000000"
              Grid.RowSpan="3"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch"
      Panel.ZIndex="999">

            <Border Width="750"
            Height="320"
            Background="#1E1E1E"
            CornerRadius="16"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="15">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 🎬 LEFT: POSTER -->
                    <Border Grid.RowSpan="2"
                    CornerRadius="12"
                    ClipToBounds="True"
                    Margin="0,0,15,0">
                        <Image x:Name="imgPoster"
                       Stretch="Fill"/>
                    </Border>

                    <!-- 🎬 CENTER CONTENT -->
                    <StackPanel Grid.Column="1">

                        <!-- TITLE -->
                        <TextBlock x:Name="txtTitle"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           TextWrapping="Wrap"/>

                        <Separator Margin="0,10"/>

                        <!-- DESCRIPTION -->
                        <TextBlock x:Name="txtDescription"
                           Foreground="#CCCCCC"
                           TextWrapping="Wrap"
                           Margin="0,5"/>

                        <!-- INFO -->
                        <StackPanel Margin="0,15,0,0">

                            <TextBlock x:Name="txtGenre"
                               Foreground="#BBBBBB"
                               Margin="0,3"/>

                            <TextBlock x:Name="txtCountry"
                               Foreground="#BBBBBB"
                               Margin="0,3"/>

                            <TextBlock x:Name="txtDuration"
                               Foreground="#BBBBBB"
                               Margin="0,3"/>

                            <TextBlock x:Name="txtStatus"
                               Foreground="#4CAF50"
                               FontWeight="Bold"
                               Margin="0,3"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 🎬 BOTTOM RIGHT BUTTONS -->
                    <StackPanel Grid.Row="1"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">

                        <!-- BOOKING BUTTON -->
                        <Button Content="🎟 Đặt vé"
                        Width="120"
                        Height="35"
                        Margin="0,0,10,0"
                        Background="#E50914"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        />

                        <!-- CLOSE BUTTON -->
                        <Button Content="✕"
                        Width="40"
                        Height="35"
                        Background="#444"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="ClosePopup_Click"/>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
