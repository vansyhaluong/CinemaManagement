<Window x:Class="Cinema.GUI.Booking"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cinema.GUI"
        mc:Ignorable="d"
        Title="Booking" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>
        <!-- ================= LEFT PANEL ================= -->
        <Border Grid.Column="0" Background="#141E2B" CornerRadius="12" Padding="16">
            <StackPanel>

                <Image Height="180" Stretch="UniformToFill"/>

                <TextBlock Text="Movie Name"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,12,0,4"/>

                <TextBlock Text="Action • 2h 10m"
                           Foreground="#7A90A8"
                           FontSize="12"/>

                <Separator Margin="0,12"/>

                <TextBlock Text="Select Showtime"
                           Foreground="#7A90A8"/>
                <WrapPanel Margin="0,8">
                    <Button Content="10:00" Margin="4" Width="70"/>
                    <Button Content="13:00" Margin="4" Width="70"/>
                    <Button Content="16:00" Margin="4" Width="70"/>
                    <Button Content="19:00" Margin="4" Width="70"/>
                </WrapPanel>

            </StackPanel>
        </Border>
        <!-- ================= CENTER SEAT MAP ================= -->
        <Border Grid.Column="1" Margin="20,0" Background="#141E2B" CornerRadius="12" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="SCREEN"
                           Foreground="#7A90A8"
                           HorizontalAlignment="Center"/>
                <!-- SEATS -->
                <UniformGrid Grid.Row="1" Rows="8" Columns="12" Margin="20">

                    <!-- SAMPLE SEATS (repeat dynamically later) -->
                    <Button Content="A1" Margin="4" Background="#1A2535" Foreground="White"/>
                    <Button Content="A2" Margin="4" Background="#1A2535" Foreground="White"/>
                    <Button Content="A3" Margin="4" Background="#1A2535" Foreground="White"/>
                    <Button Content="A4" Margin="4" Background="#4A8EF5" Foreground="White"/>
                    <Button Content="A5" Margin="4" Background="#1A2535" Foreground="White"/>

                    <Button Content="B1" Margin="4" Background="#1A2535"/>
                    <Button Content="B2" Margin="4" Background="#F5A623"/>
                    <Button Content="B3" Margin="4" Background="#1A2535"/>
                    <Button Content="B4" Margin="4" Background="#1A2535"/>

                    <Button Content="C1" Margin="4" Background="#1A2535"/>
                    <Button Content="C2" Margin="4" Background="#1A2535"/>
                    <Button Content="C3" Margin="4" Background="#F55A5A"/>

                </UniformGrid>
            </Grid>
        </Border>
        <!-- ================= RIGHT PANEL ================= -->
        <Border Grid.Column="2" Background="#141E2B" CornerRadius="12" Padding="16">
            <StackPanel>

                <TextBlock Text="Your Ticket"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="Bold"/>

                <Separator Margin="0,10"/>

                <TextBlock Text="Selected Seats"
                           Foreground="#7A90A8"/>
                <TextBlock Text="A4, B2, C3"
                           Foreground="White"
                           Margin="0,4"/>

                <TextBlock Text="Cinema"
                           Foreground="#7A90A8"
                           Margin="0,12,0,0"/>
                <TextBlock Text="Cinema CGV Example"
                           Foreground="White"/>
                <TextBlock Text="Time"
                           Foreground="#7A90A8"
                           Margin="0,12,0,0"/>
                <TextBlock Text="19:00 - Today"
                           Foreground="White"/>

                <Separator Margin="10"/>

                <!--<StackPanel Orientation="Horizontal" HorizontalAlignment="SpaceBetween">
                    <TextBlock Text="Total"
                               Foreground="#7A90A8"/>
                    <TextBlock Text="$12.00"
                               Foreground="#34C780"
                               FontSize="16"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"/>
                </StackPanel>-->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Total" Foreground="#7A90A8"/>

                    <TextBlock Grid.Column="1" Text="$12.00" Foreground="#34C780"
FontSize="16"
FontWeight="Bold"
HorizontalAlignment="Right"/>
                </Grid>
                <Button Content="Checkout"
                        Background="#4A8EF5"
                        Foreground="White"
                        Margin="0,20,0,0"
                        Height="40"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>
