<UserControl x:Class="Cinema.GUI.KhuyenMai"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1280"
             Background="#0F172A">
    <Grid Background="#0F172A">
        <Grid.Resources>
            <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#111827"/>
            <SolidColorBrush x:Key="PanelMutedBrush" Color="#1E293B"/>
            <SolidColorBrush x:Key="PanelBorderBrush" Color="#334155"/>
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#94A3B8"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>

            <Style x:Key="StatCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Padding" Value="18"/>
                <Setter Property="Margin" Value="0,0,14,0"/>
            </Style>

            <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Padding" Value="14,0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Background" Value="{StaticResource PanelMutedBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="CaretBrush" Value="White"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background" Value="{StaticResource PanelMutedBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>

            <Style x:Key="FilterButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ActionButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="34"/>
                <Setter Property="MinWidth" Value="84"/>
                <Setter Property="Padding" Value="14,0"/>
                <Setter Property="Background" Value="{StaticResource PanelMutedBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#273449"/>
                        <Setter Property="BorderBrush" Value="#475569"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="EditActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                <Setter Property="Foreground" Value="#93C5FD"/>
                <Setter Property="BorderBrush" Value="#3B82F6"/>
            </Style>
        </Grid.Resources>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    CornerRadius="18"
                    Padding="24"
                    Margin="0,0,0,18">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="QUẢN LÝ KHUYẾN MÃI"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Theo dõi chương trình giảm giá, tình trạng áp dụng và thời gian hiệu lực."
                                   FontSize="13"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <Button Content="+ Tạo khuyến mãi"
                            DockPanel.Dock="Right"
                            Width="156"
                            Height="42"
                            Margin="18,0,0,0"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Click="btnThemKhuyenMai_Click"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="12">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DockPanel>
            </Border>

            <UniformGrid Grid.Row="1"
                         Columns="4"
                         Margin="0,0,0,18">
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Tổng khuyến mãi"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="13"/>
                        <TextBlock x:Name="txtTongKhuyenMai"
                                   Text="0"
                                   Margin="0,12,0,0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Đang hoạt động"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="13"/>
                        <TextBlock x:Name="txtDangHoatDong"
                                   Text="0"
                                   Margin="0,12,0,0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#22C55E"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Sắp hết hạn"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="13"/>
                        <TextBlock x:Name="txtSapHetHan"
                                   Text="0"
                                   Margin="0,12,0,0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#F59E0B"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="Đã hết hạn"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="13"/>
                        <TextBlock x:Name="txtDaHetHan"
                                   Text="0"
                                   Margin="0,12,0,0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#F87171"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="18"
                    Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.1*"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="txtTimKiem"
                             Grid.Column="0"
                             Style="{StaticResource InputTextBoxStyle}"
                             TextChanged="FilterChanged"
                             ToolTip="Tìm mã hoặc tên khuyến mãi"/>

                    <ComboBox x:Name="cbTrangThai"
                              Grid.Column="1"
                              Margin="14,0,0,0"
                              Height="35"
                              
                              Foreground="{StaticResource SecondaryTextBrush}"
                              Style="{StaticResource InputComboBoxStyle}"
                              SelectionChanged="FilterChanged">
                        <ComboBoxItem Content="Tất cả trạng thái" IsSelected="True"/>
                        <ComboBoxItem Content="Đang hoạt động"/>
                        <ComboBoxItem Content="Sắp áp dụng"/>
                        <ComboBoxItem Content="Sắp hết hạn"/>
                        <ComboBoxItem Content="Tạm dừng"/>
                        <ComboBoxItem Content="Đã hết hạn"/>
                    </ComboBox>

                    <ComboBox x:Name="cbLoai"
                              Grid.Column="2"
                              Margin="14,0,0,0"
                              
                              Style="{StaticResource InputComboBoxStyle}"
                              Foreground="{StaticResource SecondaryTextBrush}"
                              Height="35"
                              SelectionChanged="FilterChanged">
                        <ComboBoxItem Content="Tất cả loại" IsSelected="True"/>
                        <ComboBoxItem Content="Giảm tiền"/>
                        <ComboBoxItem Content="Giảm phần trăm"/>
                    </ComboBox>

                    <Button Grid.Column="3"
                            Margin="14,0,0,0"
                            Style="{StaticResource FilterButtonStyle}"
                            Content="Làm mới"
                            Click="btnLamMoi_Click"/>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="18">
                <Grid>
                    <TextBlock x:Name="txtEmptyState"
                               Text="Chưa có khuyến mãi phù hợp với bộ lọc hiện tại."
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="icKhuyenMai">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0F172A"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Padding="18"
                                            Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding HienThiMa}"
                                                               FontSize="20"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                                    <Border Background="{Binding TrangThaiNen}"
                                                            CornerRadius="999"
                                                            Padding="10,4"
                                                            Margin="12,0,0,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TrangThaiHienThi}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding TrangThaiChu}"/>
                                                    </Border>
                                                </StackPanel>

                                                <TextBlock Text="{Binding MoTaHienThi}"
                                                           Margin="0,10,0,14"
                                                           FontSize="14"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           TextWrapping="Wrap"/>

                                                <WrapPanel>
                                                    <Border Background="{StaticResource PanelMutedBrush}"
                                                            CornerRadius="8"
                                                            Padding="12,8"
                                                            Margin="0,0,10,10">
                                                        <StackPanel>
                                                            <TextBlock Text="Loại"
                                                                       Foreground="#64748B"
                                                                       FontSize="11"/>
                                                            <TextBlock Text="{Binding LoaiGiamHienThi}"
                                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                                       FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Background="{StaticResource PanelMutedBrush}"
                                                            CornerRadius="8"
                                                            Padding="12,8"
                                                            Margin="0,0,10,10">
                                                        <StackPanel>
                                                            <TextBlock Text="Hiệu lực"
                                                                       Foreground="#64748B"
                                                                       FontSize="11"/>
                                                            <TextBlock Text="{Binding HieuLucText}"
                                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                                       FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Background="{StaticResource PanelMutedBrush}"
                                                            CornerRadius="8"
                                                            Padding="12,8"
                                                            Margin="0,0,10,10">
                                                        <StackPanel>
                                                            <TextBlock Text="Đã sử dụng"
                                                                       Foreground="#64748B"
                                                                       FontSize="11"/>
                                                            <TextBlock Text="{Binding DaSuDungText}"
                                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                                       FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Background="{StaticResource PanelMutedBrush}"
                                                            CornerRadius="8"
                                                            Padding="12,8"
                                                            Margin="0,0,10,10">
                                                        <StackPanel>
                                                            <TextBlock Text="Đơn tối thiểu"
                                                                       Foreground="#64748B"
                                                                       FontSize="11"/>
                                                            <TextBlock Text="{Binding DonToiThieuText}"
                                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                                       FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                </WrapPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Top"
                                                        Margin="24,0,0,0">
                                                <Button Content="Sửa"
                                                        Style="{StaticResource EditActionButtonStyle}"
                                                        Margin="0,0,10,0"
                                                        Tag="{Binding MaKhuyenMai}"
                                                        Click="btnSuaKhuyenMai_Click"/>
                                                <Button Content="{Binding HanhDongText}"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Foreground="{Binding HanhDongChu}"
                                                        BorderBrush="{Binding HanhDongVien}"
                                                        Tag="{Binding MaKhuyenMai}"
                                                        Click="btnTrangThaiKhuyenMai_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

