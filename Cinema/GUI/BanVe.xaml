<UserControl x:Class="Cinema.GUI.BanVe"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="820"
             d:DesignWidth="1400"
             Background="#0F172A">

    <UserControl.Resources>
        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="SoftPanel" TargetType="Border">
            <Setter Property="Background" Value="#111C2A"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="TextInput" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TimeButton" TargetType="Button">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ServiceIconButton" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E293B"/>
                    <Setter Property="BorderBrush" Value="#475569"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerIconButton" TargetType="Button" BasedOn="{StaticResource ServiceIconButton}">
            <Setter Property="Foreground" Value="#FCA5A5"/>
            <Setter Property="BorderBrush" Value="#7F1D1D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7F1D1D"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#991B1B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource SoftPanel}"
                Padding="22"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="txtTenPhim"
                               Foreground="#F8FAFC"
                               FontSize="30"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="txtThongTin"
                               Foreground="#A7B0C0"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Background="#2563EB"
                            Padding="10,6"
                            CornerRadius="6"
                            Margin="0,0,10,0">
                        <TextBlock Text="Bán vé"
                                   Foreground="White"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="Giữ ghế 60 giây"
                               Foreground="#A7B0C0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource SoftPanel}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Suất chiếu"
                                   Style="{StaticResource PanelTitle}"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="panelNgaySuatChieu"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource SoftPanel}">
                    <StackPanel>
                        <TextBlock Text="Dịch vụ"
                                   Style="{StaticResource PanelTitle}"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="cbDichVu"
                                      Height="34"
                                      Background="#0F172A"
                                      Foreground="#111827"
                                      BorderBrush="#334155"/>

                            <Button Grid.Column="1"
                                    Content="+ Thêm"
                                    Margin="10,0,0,0"
                                    Click="btnThemDichVu_Click"
                                    Background="#2563EB"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                        </Grid>

                        <ListView x:Name="lvDichVu"
                                  MaxHeight="180"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="#F8FAFC">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E293B"
                                            CornerRadius="8"
                                            Padding="10"
                                            Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="124"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding Ten}"
                                                           Foreground="#F8FAFC"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Gia, StringFormat={}{0:N0} đ}"
                                                           Foreground="#A7B0C0"
                                                           FontSize="12"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <Button Style="{StaticResource ServiceIconButton}"
                                                        Click="btnTru_Click"
                                                        ToolTip="Giảm số lượng">
                                                    <Path Data="M4,8 L12,8"
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="2"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"/>
                                                </Button>
                                                <TextBlock Text="{Binding SoLuong}"
                                                           Width="30"
                                                           Foreground="#F8FAFC"
                                                           FontWeight="Bold"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <Button Style="{StaticResource ServiceIconButton}"
                                                        Click="btnCong_Click"
                                                        ToolTip="Tăng số lượng">
                                                    <Path Data="M8,4 L8,12 M4,8 L12,8"
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="2"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"/>
                                                </Button>
                                                <Button Style="{StaticResource DangerIconButton}"
                                                        Margin="8,0,0,0"
                                                        Click="btnXoa_Click"
                                                        ToolTip="Xóa dịch vụ">
                                                    <Path Data="M5,6 L11,6 M7,6 L7,13 M9,6 L9,13 M6,6 L6,14 L10,14 L10,6 M7,4 L9,4"
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.7"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tổng dịch vụ"
                                       Foreground="#A7B0C0"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtTongTienDichVu"
                                       Grid.Column="1"
                                       Text="0 đ"
                                       Foreground="#45C486"
                                       FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Column="2" Style="{StaticResource SoftPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Chọn ghế"
                                   Style="{StaticResource PanelTitle}"/>
                        <TextBlock x:Name="txtSoGhe"
                                   Grid.Column="1"
                                   Text="Chưa chọn suất"
                                   Foreground="#A7B0C0"/>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Margin="70,0,70,20">
                        <Border Height="10"
                                Background="#E7E1CF"
                                CornerRadius="5"/>
                        <TextBlock Text="MÀN HÌNH"
                                   Foreground="#A7B0C0"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="spGhe"
                                    HorizontalAlignment="Center"
                                    Margin="10"/>
                    </ScrollViewer>

                    <WrapPanel Grid.Row="3"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,0">
                        <TextBlock Text="Trống" Foreground="#A7B0C0" Margin="8,0"/>
                        <Border Width="14" Height="14" Background="#334155" CornerRadius="3"/>
                        <TextBlock Text="Đang chọn" Foreground="#A7B0C0" Margin="16,0,8,0"/>
                        <Border Width="14" Height="14" Background="#22C55E" CornerRadius="3"/>
                        <TextBlock Text="Đang giữ" Foreground="#A7B0C0" Margin="16,0,8,0"/>
                        <Border Width="14" Height="14" Background="#CA8A04" CornerRadius="3"/>
                        <TextBlock Text="Đã bán" Foreground="#A7B0C0" Margin="16,0,8,0"/>
                        <Border Width="14" Height="14" Background="#991B1B" CornerRadius="3"/>
                        <TextBlock Text="Bảo trì" Foreground="#A7B0C0" Margin="16,0,8,0"/>
                        <Border Width="14" Height="14" Background="#64748B" CornerRadius="3"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource SoftPanel}">
                <StackPanel>
                    <TextBlock Text="Thông tin khách hàng"
                               Style="{StaticResource PanelTitle}"/>

                    <TextBlock Text="Số điện thoại"
                               Foreground="#A7B0C0"/>
                    <TextBox x:Name="txtSoDienThoai"
                             Style="{StaticResource TextInput}"
                             Margin="0,6,0,12"/>

                    <TextBlock Text="Họ tên"
                               Foreground="#A7B0C0"/>
                    <TextBox x:Name="txtKhachHang"
                             Style="{StaticResource TextInput}"
                             Margin="0,6,0,16"/>

                    <TextBlock Text="Phương thức thanh toán"
                               Foreground="#A7B0C0"/>
                    <ComboBox x:Name="cbPhuongThuc"
                              Height="38"
                              Margin="0,6,0,18"
                              SelectedIndex="0">
                        <ComboBoxItem Content="TienMat"/>
                        <ComboBoxItem Content="ChuyenKhoan"/>
                        <ComboBoxItem Content="The"/>
                    </ComboBox>

                    <Separator Margin="0,0,0,18"/>

                    <TextBlock Text="Ghế đang chọn"
                               Foreground="#A7B0C0"/>
                    <TextBlock x:Name="txtGheDangChon"
                               Text="Chưa chọn ghế"
                               Foreground="#F8FAFC"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,6,0,16"/>

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Tiền vé" Foreground="#A7B0C0"/>
                        <TextBlock x:Name="txtTongTienVe" Grid.Column="1" Text="0 đ" Foreground="#F8FAFC"/>
                    </Grid>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Dịch vụ" Foreground="#A7B0C0"/>
                        <TextBlock x:Name="txtTongDichVuTomTat" Grid.Column="1" Text="0 đ" Foreground="#F8FAFC"/>
                    </Grid>

                    <Border Height="1"
                            Background="#334155"
                            Margin="0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Tổng thanh toán"
                                   Foreground="#F8FAFC"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtTongThanhToan"
                                   Grid.Column="1"
                                   Text="0 đ"
                                   Foreground="#22C55E"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                    </Grid>

                    <Button x:Name="btnThanhToan"
                            Content="XÁC NHẬN THANH TOÁN"
                            Height="46"
                            Margin="0,22,0,0"
                            Background="#22C55E"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnThanhToan_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
