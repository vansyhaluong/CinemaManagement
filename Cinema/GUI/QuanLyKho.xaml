<UserControl x:Class="Cinema.GUI.QuanLyKho"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cinema.GUI"
             mc:Ignorable="d" 
             xmlns:controls="clr-namespace:Cinema.Controls"
             d:DesignHeight="450" d:DesignWidth="800">
    <!-- Content area -->
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar loại sản phẩm -->
        <Border Grid.Column="0"
                Background="{DynamicResource AppBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0"
                Padding="14">
            <StackPanel>
                <TextBlock Text="DANH MỤC"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,0,0,12"/>

                <Button Content="📦 Tất cả sản phẩm"
                        Height="38"
                        Margin="0,0,0,8"
                        Click="BtnTatCa_Click"/>
                <ItemsControl x:Name="icLoaiSanPham">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding TenLoai}"
                    Height="38"
                    Margin="0,0,0,8"
                    Click="BtnLocLoai_Click"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!--<Button Content="🍿 Bắp rang"
                        Height="38"
                        Margin="0,0,0,8"
                        Click="BtnLocLoai_Click"/>

                <Button Content="🥤 Nước uống"
                        Height="38"
                        Margin="0,0,0,8"
                        Click="BtnLocLoai_Click"/>

                <Button Content="🍫 Snack"
                        Height="38"
                        Margin="0,0,0,8"
                        Click="BtnLocLoai_Click"/>-->
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="94"/>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Stat cards -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal"
                            Margin="16,10"
                            VerticalAlignment="Center">

                    <controls:StatCard x:Name="cardTongSP"
                                       CardLabel="Tổng sản phẩm"
                                       Value="0"
                                       SubLabel="Đang kinh doanh"
                                       ValueBrushKey="TextPrimaryBrush"
                                       Margin="0,0,10,0"/>

                    <controls:StatCard x:Name="cardTongTon"
                                       CardLabel="Tổng tồn kho"
                                       Value="0"
                                       SubLabel="Trong kho"
                                       ValueBrushKey="SuccessBrush"
                                       Margin="0,0,10,0"/>

                    <controls:StatCard x:Name="cardSapHet"
                                       CardLabel="Sắp hết"
                                       Value="0"
                                       SubLabel="Dưới 10"
                                       ValueBrushKey="WarningBrush"
                                       Margin="0,0,10,0"/>

                    <controls:StatCard x:Name="cardHetHang"
                                       CardLabel="Hết hàng"
                                       Value="0"
                                       SubLabel="Cần nhập"
                                       ValueBrushKey="DangerBrush"/>
                </StackPanel>
            </Border>

            <!-- Filter bar -->
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="16,8">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBox Width="260"
                                 Height="34"
                                 x:Name="txtSearch"
                                 Text="Tìm sản phẩm..."
                                 TextChanged="TxtSearch_TextChanged"
                                 Margin="0,0,10,0"/>

                        <ComboBox Width="150"
                                  Height="34"
                                  x:Name="cmbStatus"
                                  SelectedIndex="0"
                                  SelectionChanged="CmbStatus_SelectionChanged"
                                  Margin="0,0,10,0">
                            <ComboBoxItem>Tất cả trạng thái</ComboBoxItem>
                            <ComboBoxItem>Còn hàng</ComboBoxItem>
                            <ComboBoxItem>Sắp hết</ComboBoxItem>
                            <ComboBoxItem>Hết hàng</ComboBoxItem>
                        </ComboBox>

                        <Button Content="🔍 Lọc"
                                Width="80"
                                Height="34"
                                Click="BtnLoc_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="+ Nhập kho"
                                Style="{StaticResource AccentButton}"
                                Width="110"
                                Height="34"
                                Margin="0,0,8,0"
                                Click="BtnNhapKho_Click"/>

                        <Button Content="+ Sản phẩm"
                                Width="110"
                                Height="34"
                                Click="BtnThemSanPham_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Product cards -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="icSanPham"
                              Margin="16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="210"
                                    Height="285"
                                    Margin="0,0,16,16"
                                    Padding="12"
                                    CornerRadius="18"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="120"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="38"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            CornerRadius="14"
                                            Background="{DynamicResource AppBackgroundBrush}"
                                            ClipToBounds="True">
                                        <Image Source="{Binding HinhAnh}"
                                               Stretch="Uniform"/>
                                    </Border>

                                    <StackPanel Grid.Row="1"
                                                Margin="0,12,0,0">
                                        <TextBlock Text="{Binding Ten}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Text="{Binding TenLoai}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="0,3,0,8"/>

                                        <TextBlock Text="{Binding GiaDisplay}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SuccessBrush}"/>

                                        <Grid Margin="0,8,0,0">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HienSoLuongTon}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <TextBlock Text="Tồn kho"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Left"/>

                                            <TextBlock Text="{Binding SoLuongTon}"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>

                                        <Border Margin="0,10,0,0"
                                                Height="26"
                                                CornerRadius="13"
                                                Background="{Binding StatusBrush}">
                                            <!--<TextBlock Text="{Binding TrangThaiKho}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"/>-->
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom">
                                        <Button Content="Sửa"
                                                Width="58"
                                                Height="30"
                                                Margin="0,0,6,0"
                                                Click="BtnSua_Click"/>

                                        <Button Content="Xóa"
                                        Width="58"
                                        Height="30"
                                        Background="#DC2626"
                                        Foreground="White"
                                        Click="BtnXoa_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
