<Window x:Class="Cinema.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cinema"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:controls="clr-namespace:Cinema.Controls"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar — NavItem UserControls ────────────────── -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <StackPanel Margin="0">

                    <!-- Logo area -->
                    <StackPanel Margin="16,16,16,16">
                        <TextBlock Text="CGV"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="v2.1"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,8"/>

                    <TextBlock Text="MAIN"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="16,0,0,6"/>

                    <!-- ── STEP 5: NavItem UserControls ─────────
                         Replace the plain TextBlock nav labels.
                         IsActive, BadgeCount are DependencyProperties.
                         Theme toggle updates colours automatically.
                    ─────────────────────────────────────────────── -->
                    <controls:NavItem Icon="🏠" Label="Danh sách phim" IsActive="True" />
                    <controls:NavItem Icon="▦"  Label="Inventory" MouseLeftButtonDown="Movie_Click"/>
                    <!--<controls:NavItem Icon="🎟" Label="Booking"/>-->
                    <controls:NavItem Icon="🛒" Label="Purchase Orders" BadgeCount="3"/>
                    <!--<controls:NavItem Icon="🏢" Label="Suppliers"/>-->

                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,8"/>

                    <TextBlock Text="ANALYTICS"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="16,0,0,6"/>

                    <controls:NavItem Icon="📊" Label="Reports"/>
                    <controls:NavItem Icon="📈" Label="Trends"/>

                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,8"/>

                    <TextBlock Text="SYSTEM"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="16,0,0,6"/>

                    <controls:NavItem Icon="⚙" Label="Settings"/>

                </StackPanel>

                <!-- User row pinned to bottom -->
                <StackPanel VerticalAlignment="Bottom" Margin="16,0,16,16"
                            Orientation="Horizontal">
                    <Border Width="28" Height="28"
                            Background="{DynamicResource AccentBrush}"
                            CornerRadius="14"
                            Margin="0,0,10,0">
                        <TextBlock Text="AD"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Admin"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Administrator"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Main panel ────────────────────────────────────── -->
        
        <Grid Grid.Column="1" x:Name="MainPage" Visibility="Visible"
              Background="{DynamicResource AppBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="84"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="42"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left">
                        <TextBlock Text="Inventory"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="38 items across 3 categories"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="☀ / ☾  Toggle Theme"
                                Margin="0,0,16,0"
                                Click="ThemeToggle_Click"/>
                        <Button Content="🖨 Print"  Margin="0,0,8,0"/>
                        <Button Content="⬇ Export" Margin="0,0,8,0"/>
                        <Button Content="+ Add Item"
                                Style="{StaticResource AccentButton}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── STEP 5: StatCard UserControls ─────────────────
                 Replace the inline Border stat blocks.
                 ValueBrushKey maps to a key in the ResourceDictionary.
                 SetResourceReference in the code-behind links it —
                 theme toggle updates the value colour automatically.
            ─────────────────────────────────────────────────────── -->
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal"
                            Margin="12,0" VerticalAlignment="Center">
                    <controls:StatCard CardLabel="Total Items"
                                       Value="38"
                                       SubLabel="Across all categories"
                                       ValueBrushKey="TextPrimaryBrush"
                                       Margin="0,0,10,0"/>
                    <controls:StatCard CardLabel="Total Value"
                                       Value="$24.9k"
                                       SubLabel="Inventory value"
                                       ValueBrushKey="SuccessBrush"
                                       Margin="0,0,10,0"/>
                    <controls:StatCard CardLabel="Low Stock"
                                       Value="6"
                                       SubLabel="Below threshold"
                                       ValueBrushKey="WarningBrush"
                                       Margin="0,0,10,0"/>
                    <controls:StatCard CardLabel="Out of Stock"
                                       Value="2"
                                       SubLabel="Needs reorder"
                                       ValueBrushKey="DangerBrush"/>
                </StackPanel>
            </Border>

            <!-- Content area -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filter bar -->
                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            Margin="12,8" VerticalAlignment="Center">
                    <TextBox Width="220" Margin="0,0,8,0"
                             Text="Search items..."
                             x:Name="txtSearch"/>
                    <ComboBox Width="140" Margin="0,0,8,0"
                              SelectedIndex="0"
                              x:Name="cmbCategory">
                        <ComboBoxItem>All Categories</ComboBoxItem>
                        <ComboBoxItem>Electronics</ComboBoxItem>
                        <ComboBoxItem>Furniture</ComboBoxItem>
                        <ComboBoxItem>Stationery</ComboBoxItem>
                    </ComboBox>
                    <ComboBox Width="130" SelectedIndex="0"
                              x:Name="cmbStatus">
                        <ComboBoxItem>All Status</ComboBoxItem>
                        <ComboBoxItem>Active</ComboBoxItem>
                        <ComboBoxItem>Low Stock</ComboBoxItem>
                        <ComboBoxItem>Out of Stock</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <!-- DataGrid -->
                <DataGrid Grid.Row="1" x:Name="dgvItems"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          IsReadOnly="True"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          Background="{DynamicResource AppBackgroundBrush}"
                          Foreground="{DynamicResource TextSecondaryBrush}"
                          RowBackground="{DynamicResource AppBackgroundBrush}"
                          AlternatingRowBackground="{DynamicResource AppBackgroundBrush}"
                          HorizontalGridLinesBrush="{DynamicResource BorderBrush}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"      Value="{DynamicResource AppBackgroundBrush}"/>
                            <Setter Property="Foreground"      Value="{DynamicResource TextMutedBrush}"/>
                            <Setter Property="FontSize"        Value="11"/>
                            <Setter Property="Padding"         Value="12,8"/>
                            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="50">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="FontSize"   Value="12"/>
                                    <Setter Property="Padding"    Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="ITEM NAME"    Binding="{Binding Name}"               Width="*"/>
                        <DataGridTextColumn Header="CATEGORY"     Binding="{Binding Category}"           Width="100"/>
                        <DataGridTextColumn Header="IN STOCK"     Binding="{Binding Qty}"                Width="70"/>
                        <DataGridTextColumn Header="UNIT PRICE"   Binding="{Binding PriceDisplay}"       Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="FontSize"   Value="12"/>
                                    <Setter Property="Padding"    Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="SUPPLIER"     Binding="{Binding Supplier}"           Width="120"/>
                        <DataGridTextColumn Header="LAST UPDATED" Binding="{Binding LastUpdatedDisplay}" Width="110"/>
                        <DataGridTextColumn Header="STATUS"       Binding="{Binding Status}"             Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Bottom bar -->
            <Border Grid.Row="3"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="14,0">
                    <TextBlock x:Name="lblPageInfo"
                               Text="Showing 10 of 38 items"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="‹" Margin="0,0,4,0" Width="28" Height="26" Padding="0"/>
                        <Button Content="1" Margin="0,0,4,0" Width="28" Height="26" Padding="0"/>
                        <Button Content="2" Margin="0,0,4,0" Width="28" Height="26" Padding="0"/>
                        <Button Content="3" Margin="0,0,4,0" Width="28" Height="26" Padding="0"/>
                        <Button Content="4" Margin="0,0,4,0" Width="28" Height="26" Padding="0"/>
                        <Button Content="›"                  Width="28" Height="26" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <ContentControl x:Name="MainContent"
                Grid.Column="1"
                Visibility="Collapsed"/>
    </Grid>
</Window>
