<Window x:Class="Cinema.GUI.ThemKhuyenMai"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Thêm khuyến mãi"
        Height="620"
        Width="900"
        MinHeight="600"
        MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#111827"/>
        <SolidColorBrush x:Key="PanelMutedBrush" Color="#172131"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#2A3A4F"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>

        <Style x:Key="ShellCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="{StaticResource PanelMutedBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="{StaticResource PanelMutedBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="InputDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="{StaticResource PanelMutedBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="{StaticResource PanelMutedBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Border Margin="20"
                Padding="20"
                Style="{StaticResource ShellCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,18">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="THÊM KHUYẾN MÃI"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Thiết lập nhanh một chương trình giảm giá mới."
                                   Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </DockPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,0,6,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.25*"/>
                            <ColumnDefinition Width="0.95*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,16,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Padding="18"
                                    Margin="0,0,0,14"
                                    Style="{StaticResource ShellCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Tên khuyến mãi" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="txtTenKhuyenMai" Style="{StaticResource InputTextBoxStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="Mã code" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="txtMaCode" Style="{StaticResource InputTextBoxStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1"
                                    Padding="18"
                                    Margin="0,0,0,14"
                                    Style="{StaticResource ShellCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Thông tin chính" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="Nội dung hiển thị và điều kiện áp dụng."
                                               Margin="0,4,0,14"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="12"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="Loại giảm" Style="{StaticResource FieldLabelStyle}"/>
                                            <ComboBox x:Name="cbLoaiGiam" Style="{StaticResource InputComboBoxStyle}">
                                                <ComboBoxItem Content="Giảm tiền"/>
                                                <ComboBoxItem Content="Giảm phần trăm"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="Trạng thái" Style="{StaticResource FieldLabelStyle}"/>
                                            <ComboBox x:Name="cbTrangThai" Style="{StaticResource InputComboBoxStyle}">
                                                <ComboBoxItem Content="Đang hoạt động"/>
                                                <ComboBoxItem Content="Tạm dừng"/>
                                                <ComboBoxItem Content="Sắp áp dụng"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Padding="18"
                                    Style="{StaticResource ShellCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Mô tả" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="Phần mô tả ngắn giúp nhân viên dễ nhận biết chương trình."
                                               Margin="0,4,0,14"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="12"/>
                                    <TextBox x:Name="txtMoTa"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             MinHeight="148"
                                             Height="160"
                                             Padding="12,10"
                                             VerticalContentAlignment="Top"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Padding="18"
                                    Margin="0,0,0,14"
                                    Style="{StaticResource ShellCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Cấu hình giảm giá" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="Giá trị, điều kiện đơn hàng và giới hạn áp dụng."
                                               Margin="0,4,0,14"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="12"/>

                                    <TextBlock Text="Giá trị giảm" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="txtGiaTriGiam"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             Margin="0,0,0,12"/>

                                    <TextBlock Text="Đơn tối thiểu" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="txtDonToiThieu"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             Margin="0,0,0,12"/>

                                    <TextBlock Text="Số lượng áp dụng" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="txtSoLuong"
                                             Style="{StaticResource InputTextBoxStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Padding="18"
                                    Margin="0,0,0,14"
                                    Style="{StaticResource ShellCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Hiệu lực" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="Thiết lập khoảng thời gian áp dụng."
                                               Margin="0,4,0,14"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="12"/>

                                    <TextBlock Text="Ngày bắt đầu" Style="{StaticResource FieldLabelStyle}"/>
                                    <DatePicker x:Name="dpNgayBatDau"
                                                Style="{StaticResource InputDatePickerStyle}"
                                                Margin="0,0,0,12"/>

                                    <TextBlock Text="Ngày kết thúc" Style="{StaticResource FieldLabelStyle}"/>
                                    <DatePicker x:Name="dpNgayKetThuc"
                                                Style="{StaticResource InputDatePickerStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Padding="18"
                                    Style="{StaticResource ShellCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Xem nhanh" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="Bản xem trước cấu hình để kiểm tra nhanh trước khi lưu."
                                               Margin="0,4,0,14"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="12"/>

                                    <Border Background="{StaticResource PanelMutedBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="Khuyến mãi mới"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       FontSize="18"
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="Giảm giá cho vé và dịch vụ theo điều kiện đã chọn."
                                                       Margin="0,6,0,14"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"/>

                                            <WrapPanel>
                                                <Border Background="#1E3A8A"
                                                        CornerRadius="999"
                                                        Padding="10,5"
                                                        Margin="0,0,8,8">
                                                    <TextBlock Text="Giá trị giảm"
                                                               Foreground="White"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                                <Border Background="#1F2937"
                                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="999"
                                                        Padding="10,5"
                                                        Margin="0,0,8,8">
                                                    <TextBlock Text="Điều kiện đơn"
                                                               Foreground="#CBD5E1"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                                <Border Background="#1F2937"
                                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="999"
                                                        Padding="10,5"
                                                        Margin="0,0,0,8">
                                                    <TextBlock Text="Thời gian áp dụng"
                                                               Foreground="#CBD5E1"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>

                <DockPanel Grid.Row="2" Margin="0,18,0,0" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Text="Kiểm tra thông tin trước khi lưu để tránh trùng mã và sai thời gian hiệu lực."
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"/>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="btnHuy"
                                Content="Hủy"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,0"/>
                        <Button x:Name="btnLuu"
                                Content="Lưu khuyến mãi"
                                Click="btnLuu_Click"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
