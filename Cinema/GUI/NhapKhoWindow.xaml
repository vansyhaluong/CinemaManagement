<Window x:Class="Cinema.GUI.NhapKhoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cinema.GUI"
        mc:Ignorable="d"
        Title="Tạo phiếu nhập kho"
        Width="920"
        Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="📦 Tạo phiếu nhập kho"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                <TextBlock Text="Chọn sản phẩm, nhập số lượng và lưu phiếu nhập"
                           FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- Left content -->
            <Grid Grid.Column="0"
                  Margin="0,0,18,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="130"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Add item card -->
                <Border Grid.Row="0"
                        Padding="18"
                        CornerRadius="18"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,14,0">
                            <TextBlock Text="Sản phẩm"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"/>

                            <ComboBox x:Name="cbSanPham"
                                      Height="38"
                                      Margin="0,8,0,0"
                                      DisplayMemberPath="Ten"
                                      SelectedValuePath="MaSanPham"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="0,0,14,0">
                            <TextBlock Text="Số lượng"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"/>

                            <TextBox x:Name="txtSoLuong"
                                     Height="38"
                                     Margin="0,8,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="2" 
                                Content="+ Thêm"
                                Height="38"
                                
                                Style="{StaticResource AccentButton}"
                                Click="BtnThemDong_Click"/>
                    </Grid>
                </Border>

                <!-- Detail list -->
                <Border Grid.Row="1"
                        Margin="0,16,0,0"
                        Padding="16"
                        CornerRadius="18"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="38"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Danh sách sản phẩm nhập"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icChiTietNhap">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                CornerRadius="14"
                                                Background="{DynamicResource AppBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="42"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding TenSanPham}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                                                    <TextBlock Text="{Binding TenLoai}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding SoLuong}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding GiaDisplay}"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource SuccessBrush}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"/>

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding ThanhTienDisplay}"
                                                           FontSize="13"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"/>

                                                <Button Grid.Column="4"
                                                        Content="X"
                                                        Width="30"
                                                        Height="30"
                                                        Background="#DC2626"
                                                        Foreground="White"
                                                        Click="BtnXoaDong_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right summary -->
            <Border Grid.Column="1"
                    Padding="18"
                    CornerRadius="18"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Tổng kết phiếu"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,20"/>

                    <Border Grid.Row="1"
                            Padding="12"
                            CornerRadius="14"
                            Background="{DynamicResource AppBackgroundBrush}"
                            Margin="0,0,0,12">
                        <Grid>
                            <TextBlock Text="Số mặt hàng"
                                       Foreground="{DynamicResource TextMutedBrush}"/>

                            <TextBlock x:Name="txtTongMatHang"
                                       Text="0"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Padding="12"
                            CornerRadius="14"
                            Background="{DynamicResource AppBackgroundBrush}">
                        <Grid>
                            <TextBlock Text="Tổng số lượng"
                                       Foreground="{DynamicResource TextMutedBrush}"/>

                            <TextBlock x:Name="txtTongSoLuong"
                                       Text="0"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       Foreground="{DynamicResource WarningBrush}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="3"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,24">
                        <TextBlock Text="Tổng tiền"
                                   Foreground="{DynamicResource TextMutedBrush}"/>

                        <TextBlock x:Name="txtTongTien"
                                   Text="0 đ"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4">
                        <Button Content="Lưu phiếu nhập"
            Height="42"
            Style="{StaticResource AccentButton}"
            Click="BtnLuuPhieu_Click"/>

                        <Button Content="In phiếu nhập"
            Height="38"
            Margin="0,10,0,0"
            Click="BtnInPhieu_Click"/>

                        <Button Content="Hủy"
            Height="38"
            Margin="0,10,0,0"
            Click="BtnHuy_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
