<UserControl x:Class="Cinema.GUI.ChamCong"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cinema.GUI"
             mc:Ignorable="d" 
             xmlns:controls="clr-namespace:Cinema.Controls"
             d:DesignHeight="450" d:DesignWidth="800">


    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="84"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="42"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Chấm công nhân viên"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Theo dõi check-in, check-out và trạng thái ca làm"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="txtTime"
                               Text="00:00:00"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="txtDate"
                               Text="dd/MM/yyyy"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- STAT CARDS -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal"
                        Margin="12,0"
                        VerticalAlignment="Center">

                <controls:StatCard CardLabel="Đúng giờ"
                                   x:Name="cardActive"
                                   Value="0"
                                   SubLabel="Check-in hợp lệ"
                                   ValueBrushKey="SuccessBrush"
                                   Margin="0,0,10,0"/>

                <controls:StatCard CardLabel="Đi trễ"
                                   x:Name="cardLate"
                                   Value="0"
                                   SubLabel="Sau giờ bắt đầu"
                                   ValueBrushKey="WarningBrush"
                                   Margin="0,0,10,0"/>

                <controls:StatCard CardLabel="Chưa chấm công"
                                   x:Name="cardAbsent"
                                   Value="0"
                                   SubLabel="Đã phân ca nhưng chưa vào"
                                   ValueBrushKey="DangerBrush"
                                   Margin="0,0,10,0"/>

                <controls:StatCard CardLabel="Tổng ca"
                                   x:Name="cardTotal"
                                   Value="0"
                                   SubLabel="Theo ngày đã chọn"
                                   ValueBrushKey="TextPrimaryBrush"/>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- FILTER -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="12,8"
                        VerticalAlignment="Center">
                <DatePicker x:Name="dpNgay"
                            Width="150"
                            Foreground="White"
                            Margin="0,0,8,0"
                            SelectedDateChanged="dpNgay_SelectedDateChanged"/>

                <ComboBox x:Name="cbRap"
                          Width="160"
                          Margin="0,0,8,0"
                          DisplayMemberPath="TenRap"
                          SelectedValuePath="MaRap"
                          SelectionChanged="cbRap_SelectionChanged"/>

                <ComboBox x:Name="cbCa"
                          Width="150"
                          Margin="0,0,8,0"
                          DisplayMemberPath="TenCa"
                          SelectedValuePath="MaCa"
                          SelectionChanged="cbCa_SelectionChanged"/>

                <TextBox x:Name="txtSearch"
                         Width="220"
                         Margin="0,0,8,0"
                         TextChanged="txtSearch_TextChanged"/>

                <Button Content="Lọc"
                        Width="72"
                        Click="btnLoc_Click"/>
            </StackPanel>

            <!-- MAIN -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- STAFF LIST -->
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icNhanVien">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="14,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding HoTen}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}">
                                                <Run Text="{Binding ThoiGianCa, Mode=OneWay}"/>
                                                <Run Text=" • "/>
                                                <Run Text="{Binding TenCa, Mode=OneWay}"/>
                                                <Run Text=" • "/>
                                                <Run Text="{Binding ThoiGianCa, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding GioVaoText}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding GioRaText}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TrangThai}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="3"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                            <Button Content="IN"
                                                    Width="46"
                                                    Margin="0,0,6,0"
                                                    Tag="{Binding}"
                                                    Click="btnCheckIn_Click"/>
                                            <Button Content="OUT"
                                                    Width="52"
                                                    Margin="0,0,6,0"
                                                    Tag="{Binding}"
                                                    Click="btnCheckOut_Click"/>
                                            <Button Content="Sửa"
                                                    Width="52"
                                                    Tag="{Binding}"
                                                    Click="btnSuaTrangThai_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- TIMELINE -->
                <Border Grid.Column="1"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1,0,0,0"
                        Padding="14,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Activity Timeline"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>

                        <ItemsControl Grid.Row="1" x:Name="icLog">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding ThoiGian}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding NoiDung}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- BOTTOM -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <TextBlock x:Name="lblPageInfo"
                           Text="Showing 0 attendance records"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
