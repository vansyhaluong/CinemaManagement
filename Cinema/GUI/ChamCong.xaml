<UserControl x:Class="Cinema.GUI.ChamCong"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cinema.GUI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#070B16" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,22">
            <StackPanel>
                <TextBlock Text="Chấm công nhân viên"
                       Foreground="White"
                       FontSize="32"
                       FontWeight="Bold"/>

                <TextBlock Text="Theo dõi giờ vào, giờ ra và trạng thái làm việc trong ngày"
                       Foreground="#94A3B8"
                       FontSize="14"
                       Margin="0,6,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">

                <Button Content="Chấm vào"
                    Width="120"
                    Height="40"
                    Margin="0,0,10,0"
                    Background="#22C55E"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Click="btnChamVao_Click"/>

                <Button Content="Chấm ra"
                    Width="120"
                    Height="40"
                    Background="#3B82F6"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Click="btnChamRa_Click"/>
            </StackPanel>
        </Grid>

        <!-- KPI CARDS -->
        <Grid Grid.Row="1" Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Background="#101827" CornerRadius="20" Padding="18" Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Đang làm" Foreground="#94A3B8" FontSize="13"/>
                    <TextBlock x:Name="txtDangLam" Text="12" Foreground="White" FontSize="30" FontWeight="Bold"/>
                    <TextBlock Text="Nhân viên check-in" Foreground="#22C55E" FontSize="12"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#101827" CornerRadius="20" Padding="18" Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Đi trễ" Foreground="#94A3B8" FontSize="13"/>
                    <TextBlock x:Name="txtDiTre" Text="2" Foreground="White" FontSize="30" FontWeight="Bold"/>
                    <TextBlock Text="So với giờ vào ca" Foreground="#F59E0B" FontSize="12"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#101827" CornerRadius="20" Padding="18" Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Vắng / nghỉ" Foreground="#94A3B8" FontSize="13"/>
                    <TextBlock x:Name="txtVang" Text="1" Foreground="White" FontSize="30" FontWeight="Bold"/>
                    <TextBlock Text="Chưa có chấm công" Foreground="#EF4444" FontSize="12"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="#101827" CornerRadius="20" Padding="18">
                <StackPanel>
                    <TextBlock Text="Tổng giờ hôm nay" Foreground="#94A3B8" FontSize="13"/>
                    <TextBlock x:Name="txtTongGio" Text="86.5h" Foreground="White" FontSize="30" FontWeight="Bold"/>
                    <TextBlock Text="Tính từ giờ vào / ra" Foreground="#38BDF8" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: EMPLOYEE LIST -->
            <Border Background="#101827"
                CornerRadius="22"
                Padding="18"
                Margin="0,0,18,0">

                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                           Text="Danh sách chấm công hôm nay"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,16"/>

                    <DataGrid x:Name="dgChamCong"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          RowHeight="48"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="#101827"
                          Foreground="White"
                          BorderThickness="0">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nhân viên"
                                            Binding="{Binding TenNhanVien}"
                                            Width="*"/>

                            <DataGridTextColumn Header="Ca"
                                            Binding="{Binding TenCa}"
                                            Width="100"/>

                            <DataGridTextColumn Header="Vào"
                                            Binding="{Binding GioVao, StringFormat=HH:mm}"
                                            Width="90"/>

                            <DataGridTextColumn Header="Ra"
                                            Binding="{Binding GioRa, StringFormat=HH:mm}"
                                            Width="90"/>

                            <DataGridTextColumn Header="Giờ"
                                            Binding="{Binding TongGioLam}"
                                            Width="80"/>

                            <DataGridTextColumn Header="Trạng thái"
                                            Binding="{Binding TrangThai}"
                                            Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- RIGHT: TIMELINE -->
            <Border Grid.Column="1"
                Background="#101827"
                CornerRadius="22"
                Padding="20">

                <StackPanel>
                    <TextBlock Text="Timeline hôm nay"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Ellipse Width="12" Height="12" Fill="#22C55E" Margin="0,4,12,0"/>
                        <StackPanel>
                            <TextBlock Text="08:00 - Nguyễn Văn A check-in"
                                   Foreground="White"
                                   FontSize="14"/>
                            <TextBlock Text="Ca sáng bắt đầu"
                                   Foreground="#94A3B8"
                                   FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Ellipse Width="12" Height="12" Fill="#F59E0B" Margin="0,4,12,0"/>
                        <StackPanel>
                            <TextBlock Text="08:18 - Trần Văn B đi trễ"
                                   Foreground="White"
                                   FontSize="14"/>
                            <TextBlock Text="Trễ 18 phút"
                                   Foreground="#94A3B8"
                                   FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Ellipse Width="12" Height="12" Fill="#3B82F6" Margin="0,4,12,0"/>
                        <StackPanel>
                            <TextBlock Text="12:00 - Kết thúc ca sáng"
                                   Foreground="White"
                                   FontSize="14"/>
                            <TextBlock Text="8 nhân viên đã check-out"
                                   Foreground="#94A3B8"
                                   FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="12" Height="12" Fill="#EF4444" Margin="0,4,12,0"/>
                        <StackPanel>
                            <TextBlock Text="Chưa chấm công: Lê Minh C"
                                   Foreground="White"
                                   FontSize="14"/>
                            <TextBlock Text="Ca chiều chưa check-in"
                                   Foreground="#94A3B8"
                                   FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
