<Window x:Class="Cinema.GUI.QrThanhToanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thanh toán QR"
        Width="500"
        Height="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0F172A">

    <Window.Resources>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Thanh toán chuyển khoản"
                       Foreground="#F8FAFC"
                       FontSize="26"
                       FontWeight="Bold"/>
            <TextBlock Text="Quét mã QR và xác nhận sau khi thanh toán"
                       Foreground="#94A3B8"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,20,0,20"
                Background="#111827"
                BorderBrush="#243041"
                BorderThickness="1"
                CornerRadius="14"
                Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Width="340"
                            Height="340"
                            Background="White"
                            CornerRadius="12"
                            HorizontalAlignment="Center"
                            Padding="10">
                        <Image x:Name="imgQr"
                               Stretch="Uniform"/>
                    </Border>

                    <TextBlock Text="Tổng thanh toán"
                               Style="{StaticResource LabelText}"
                               HorizontalAlignment="Center"
                               Margin="0,18,0,6"/>
                    <TextBlock x:Name="txtTongTien"
                               Foreground="#22C55E"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                    <Border Height="1"
                            Background="#243041"
                            Margin="0,20,0,20"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Ngân hàng" Style="{StaticResource LabelText}"/>
                        <TextBlock x:Name="txtNganHang" Grid.Column="1" Style="{StaticResource ValueText}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Số tài khoản" Style="{StaticResource LabelText}"/>
                        <TextBlock x:Name="txtSoTaiKhoan" Grid.Column="1" Style="{StaticResource ValueText}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Chủ tài khoản" Style="{StaticResource LabelText}"/>
                        <TextBlock x:Name="txtChuTaiKhoan" Grid.Column="1" Style="{StaticResource ValueText}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Nội dung" Style="{StaticResource LabelText}"/>
                        <TextBlock x:Name="txtNoiDung" Grid.Column="1" Style="{StaticResource ValueText}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Đóng"
                    Width="96"
                    Margin="0,0,10,0"
                    Background="#1E293B"
                    Foreground="#E5E7EB"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    Style="{StaticResource ActionButton}"
                    Click="Close_Click"/>
            <Button Content="Đã thanh toán"
                    Width="152"
                    Background="#22C55E"
                    Foreground="White"
                    Style="{StaticResource ActionButton}"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
