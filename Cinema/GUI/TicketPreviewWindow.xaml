<Window x:Class="Cinema.GUI.TicketPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xem vé"
        Width="760"
        Height="720"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A">

    <Window.Resources>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="Vé xem phim"
                           Foreground="#F8FAFC"
                           FontSize="26"
                           FontWeight="Bold"/>
                <TextBlock Text="Kiểm tra thông tin trước khi xuất PDF"
                           Foreground="#94A3B8"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border x:Name="TicketPrintArea"
                    Background="#0F172A"
                    Padding="4">
                <ItemsControl x:Name="TicketItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="660"
                                    Margin="0,0,0,18"
                                    Background="#111827"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    ClipToBounds="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="24">
                                        <Grid Margin="0,0,0,18">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenRap}"
                                                           Foreground="#F97316"
                                                           FontSize="15"
                                                           FontWeight="Bold"/>
                                                <TextBlock Text="{Binding TenPhim}"
                                                           Foreground="#F8FAFC"
                                                           FontSize="28"
                                                           FontWeight="Bold"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,14">
                                                <TextBlock Text="NGÀY CHIẾU" Style="{StaticResource LabelText}"/>
                                                <TextBlock Text="{Binding NgayChieuText}" Style="{StaticResource ValueText}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,14">
                                                <TextBlock Text="GIỜ CHIẾU" Style="{StaticResource LabelText}"/>
                                                <TextBlock Text="{Binding GioChieuText}" Style="{StaticResource ValueText}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,14">
                                                <TextBlock Text="PHÒNG CHIẾU" Style="{StaticResource LabelText}"/>
                                                <TextBlock Text="{Binding TenPhong}" Style="{StaticResource ValueText}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,14">
                                                <TextBlock Text="GHẾ" Style="{StaticResource LabelText}"/>
                                                <TextBlock Text="{Binding Ghe}" Foreground="#22C55E" FontSize="22" FontWeight="Bold"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                                                <TextBlock Text="MÃ VÉ" Style="{StaticResource LabelText}"/>
                                                <TextBlock Text="{Binding MaVe}" Style="{StaticResource ValueText}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="1">
                                                <TextBlock Text="MÃ HÓA ĐƠN" Style="{StaticResource LabelText}"/>
                                                <TextBlock Text="{Binding MaHoaDon}" Style="{StaticResource ValueText}"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border Height="1" Background="#334155" Margin="0,20"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="NGÀY LẬP VÉ" Style="{StaticResource LabelText}"/>
                                                <TextBlock Text="{Binding NgayLapVeText}" Style="{StaticResource ValueText}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="GIÁ VÉ" Style="{StaticResource LabelText}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding GiaVeText}"
                                                           Foreground="#F8FAFC"
                                                           FontSize="22"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Background="#7F1D1D"
                                            BorderBrush="#991B1B"
                                            BorderThickness="1,0,0,0">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="ADMIT"
                                                       Foreground="#FECACA"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="ONE"
                                                       Foreground="White"
                                                       FontSize="34"
                                                       FontWeight="Black"
                                                       HorizontalAlignment="Center"/>
                                            <Border Width="84"
                                                    Height="84"
                                                    Margin="0,18,0,0"
                                                    BorderBrush="#FECACA"
                                                    BorderThickness="2"
                                                    CornerRadius="8">
                                                <TextBlock Text="{Binding Ghe}"
                                                           Foreground="White"
                                                           FontSize="26"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Đóng"
                    Width="96"
                    Height="38"
                    Margin="0,0,10,0"
                    Click="Close_Click"/>
            <Button Content="Xuất PDF"
                    Width="120"
                    Height="38"
                    Background="#22C55E"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="ExportPdf_Click"/>
        </StackPanel>
    </Grid>
</Window>
