<UserControl x:Class="Cinema.GUI.QuanLyBangLuong"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cinema.GUI"
             mc:Ignorable="d" 
             xmlns:controls="clr-namespace:Cinema.Controls"
             d:DesignHeight="450" d:DesignWidth="1000">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="76"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="BẢNG LƯƠNG"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Tính lương dựa trên chấm công, khen thưởng và kỷ luật"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <DatePicker x:Name="dpTuNgay"
                                Width="130"
                                Height="30"
                                Foreground="White"
                                Margin="0,0,8,0"/>

                    <DatePicker x:Name="dpDenNgay"
                                Width="130"
                                Height="30"
                                Foreground="White"
                                Margin="0,0,8,0"/>

                    <Button x:Name="btnTinhLuong"
                            Content="Tính lương"
                            Width="105"
                            Height="30"
                            Background="#4F46E5"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- STAT CARDS -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal"
                Margin="12,8"
                VerticalAlignment="Center">

                <controls:StatCard CardLabel="Nhân viên"
                           Value="0"
                           x:Name="cardNhanVien"
                           SubLabel="Được tính lương"
                           ValueBrushKey="TextPrimaryBrush"
                           Margin="0,0,8,0"/>

                <controls:StatCard CardLabel="Tổng giờ làm"
                           Value="0"
                           x:Name="cardGioLam"
                           SubLabel="Tổng số giờ"
                           ValueBrushKey="InfoBrush"
                           Margin="0,0,8,0"/>

                <controls:StatCard CardLabel="Tổng thưởng"
                           Value="0 đ"
                           x:Name="cardThuong"
                           SubLabel="Khen thưởng"
                           ValueBrushKey="SuccessBrush"
                           Margin="0,0,8,0"/>

                <controls:StatCard CardLabel="Tổng phạt"
                           Value="0 đ"
                           x:Name="cardPhat"
                           SubLabel="Kỷ luật"
                           ValueBrushKey="DangerBrush"/>
            </StackPanel>
        </Border>

        <!-- FILTER BAR -->
        <Grid Grid.Row="2" Margin="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="txtTimKiem"
                         Width="220"
                         Height="30"
                         Text="Tìm nhân viên..."
                         Margin="0,0,8,0"/>

                <ComboBox x:Name="cbRap"
                          Width="150"
                          Height="30"
                          Margin="0,0,8,0"/>

                <ComboBox x:Name="cbTinhTrang"
                          Width="140"
                          Height="30"
                          SelectedIndex="0">
                    
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <!--<Button Content="Xuất Excel"
                        Width="95"
                        Height="30"
                        Margin="0,0,8,0"/>-->

                <Button Content="🖨 In bảng lương"
                        Width="115"
                        Height="30"
                        
                        Foreground="White"
                        Click="btnInBangLuong_Click"
                        BorderThickness="0"/>
            </StackPanel>
        </Grid>

        <!-- DATAGRID -->
        <DataGrid Grid.Row="3"
          x:Name="dgBangLuong"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True"
          GridLinesVisibility="None"
          BorderThickness="0"
          RowHeight="40"
          FontSize="13"
          Background="{DynamicResource AppBackgroundBrush}"
          HorizontalScrollBarVisibility="Auto"
          VerticalScrollBarVisibility="Auto">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="10,7"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                    <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>

                <DataGridTextColumn Header="HỌ TÊN"
                        Binding="{Binding HoTen}"
                        Width="1.4*"/>

                <DataGridTextColumn Header="CÔNG"
                        Binding="{Binding TongNgayCong}"
                        Width="90"/>

                <DataGridTextColumn Header="GIỜ"
                        Binding="{Binding TongGioLam, StringFormat={}{0:0.##}}"
                        Width="90"/>

                <DataGridTextColumn Header="TRỄ"
                        Binding="{Binding SoLanTre}"
                        Width="80"/>

                <DataGridTextColumn Header="NGHỈ"
                        Binding="{Binding SoNgayNghi}"
                        Width="80"/>

                <DataGridTextColumn Header="THƯỞNG"
                        Binding="{Binding Thuong, StringFormat={}{0:N0}}"
                        Width="100"/>

                <DataGridTextColumn Header="PHẠT"
                        Binding="{Binding Phat, StringFormat={}{0:N0}}"
                        Width="100"/>

                <DataGridTextColumn Header="LƯƠNG"
                        Binding="{Binding TongLuong, StringFormat={}{0:N0}}"
                        Width="120"/>

                
            </DataGrid.Columns>
        </DataGrid>

        <!-- BOTTOM BAR -->
        <Border Grid.Row="4"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <TextBlock x:Name="lblPageInfo"
                           Text="Chưa tính lương"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
