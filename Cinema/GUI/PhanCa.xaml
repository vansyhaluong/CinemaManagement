<UserControl x:Class="Cinema.GUI.PhanCa"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cinema.GUI"
             xmlns:controls="clr-namespace:Cinema.Controls"
             Background="{DynamicResource AppBackgroundBrush}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="84"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="42"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Phân ca nhân viên"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="txtSummary"
                               Text="Quản lý lịch làm việc theo ngày, rạp và ca làm"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Làm mới"
                            Margin="0,0,8,0"
                            Click="btnLamMoi_Click"/>
                    <Button Content="Xuất Excel"
                            Margin="0,0,8,0"/>
                    <Button Content="+ Phân ca"
                            Style="{StaticResource AccentButton}"
                            Click="btnThem_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- STAT CARDS -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal"
                        Margin="12,0"
                        VerticalAlignment="Center">

                <controls:StatCard x:Name="cardTongPhanCa"
                                   CardLabel="Tổng phân ca"
                                   Value="0"
                                   SubLabel="Trong ngày đã chọn"
                                   ValueBrushKey="TextPrimaryBrush"
                                   Margin="0,0,10,0"/>

                <controls:StatCard x:Name="cardCaSang"
                                   CardLabel="Ca sáng"
                                   Value="0"
                                   SubLabel="08:00 - 12:00"
                                   ValueBrushKey="SuccessBrush"
                                   Margin="0,0,10,0"/>

                <controls:StatCard x:Name="cardCaChieu"
                                   CardLabel="Ca chiều"
                                   Value="0"
                                   SubLabel="13:00 - 17:00"
                                   ValueBrushKey="WarningBrush"
                                   Margin="0,0,10,0"/>

                <controls:StatCard x:Name="cardCaToi"
                                   CardLabel="Ca tối"
                                   Value="0"
                                   SubLabel="18:00 - 22:00"
                                   ValueBrushKey="DangerBrush"/>

            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- FILTER BAR -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="12,8"
                        VerticalAlignment="Center">

                <DatePicker x:Name="dpNgay"
                            Width="150"
                            Margin="0,0,8,0"
                            SelectedDateChanged="dpNgay_SelectedDateChanged"/>

                <ComboBox x:Name="cbRap"
                          Width="160"
                          Margin="0,0,8,0"
                          DisplayMemberPath="TenRap"
                          SelectedValuePath="MaRap"
                          SelectionChanged="cbRap_SelectionChanged"/>

                <ComboBox x:Name="cbCa"
                          Width="150"
                          Margin="0,0,8,0"
                          DisplayMemberPath="TenCa"
                          SelectedValuePath="MaCa"
                          SelectionChanged="cbCa_SelectionChanged"/>

                <ComboBox x:Name="cbNhanVien"
                          Width="210"
                          Margin="0,0,8,0"
                          DisplayMemberPath="HoTen"
                          SelectedValuePath="MaNhanVien"/>

                <TextBox x:Name="txtSearch"
                         Width="220"
                         Margin="0,0,8,0"
                         TextChanged="txtSearch_TextChanged"/>

                <Button Content="Sửa"
                        Width="72"
                        Margin="0,0,8,0"
                        Click="btnSua_Click"/>

                <Button Content="Xóa"
                        Width="72"
                        Click="btnXoa_Click"/>
            </StackPanel>

            <!-- DATAGRID -->
            <DataGrid Grid.Row="1"
                      x:Name="dgPhanCa"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      IsReadOnly="True"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      Background="{DynamicResource AppBackgroundBrush}"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      RowBackground="{DynamicResource AppBackgroundBrush}"
                      AlternatingRowBackground="{DynamicResource AppBackgroundBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                      SelectionChanged="dgPhanCa_SelectionChanged">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding MaPhanCa}"
                                        Width="55"/>

                    <DataGridTextColumn Header="NHÂN VIÊN"
                                        Binding="{Binding HoTen}"
                                        Width="*"/>

                    <DataGridTextColumn Header="RẠP"
                                        Binding="{Binding TenRap}"
                                        Width="160"/>

                    <DataGridTextColumn Header="CA LÀM"
                                        Binding="{Binding TenCa}"
                                        Width="120"/>

                    <DataGridTextColumn Header="THỜI GIAN"
                                        Binding="{Binding ThoiGianCa}"
                                        Width="150"/>

                    <DataGridTextColumn Header="NGÀY"
                                        Binding="{Binding Ngay, StringFormat=dd/MM/yyyy}"
                                        Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- BOTTOM BAR -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <TextBlock x:Name="lblPageInfo"
                           Text="Showing 0 shift assignments"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>

                <TextBlock Text="Cinema Staff Scheduling"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
