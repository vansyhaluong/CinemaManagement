<UserControl x:Class="Cinema.GUI.BaoCaoDoanhThuNgay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:controls="clr-namespace:Cinema.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             mc:Ignorable="d" 
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             d:DesignHeight="750" d:DesignWidth="1200">

    <UserControl.Resources>

        <!-- Card -->
        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="#132231"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>

        <!-- Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Width" Value="94"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Background" Value="#0EA5E9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/> 
            
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="5">

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="#0F1923" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- TIÊU ĐỀ BÊN TRÁI -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Báo cáo doanh thu"
                   Foreground="White"
                   FontSize="30"
                   FontWeight="Bold"/>

                <TextBlock Text="Theo dõi doanh thu bán vé và dịch vụ theo từng rạp trong ngày"
                   Foreground="#8EA4B8"
                   FontSize="14"
                   Margin="0,6,0,0"/>
            </StackPanel>

            <!-- NÚT BÊN PHẢI -->
            <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">

                <Button Content="Xuất PDF"
                Width="110"
                Height="38"
                Margin="0,0,10,0"
                Click="btnXuatPdf_Click"/>

                <Button Content="Xuất Excel"
                Width="120"
                Height="38"
                Click="btnXuatExcel_Click"/>
            </StackPanel>
        </Grid>

        <!-- FILTER -->
        <Border Grid.Row="1"
                Background="#132231"
                CornerRadius="10"
                Padding="18"
                Margin="0,0,0,20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Ngày báo cáo"
                               Foreground="#8EA4B8"
                               FontSize="13"
                               Margin="0,0,0,8"/>
                    <DatePicker x:Name="dpNgayBaoCao" 
                                Height="32"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                    <TextBlock Text="Rạp chiếu"
                               Foreground="#8EA4B8"
                               FontSize="13"
                               Margin="0,0,0,8"/>
                    <ComboBox x:Name="cbRap"
                              Height="32"
                              DisplayMemberPath="TenRap"
                              SelectedValuePath="MaRap"/>
                </StackPanel>

                <Button Grid.Column="2"
                        x:Name="btnXemBaoCao"
                        Content="Xem báo cáo"
                        Click="btnXemBaoCao_Click"
                        Height="32"
                        Style="{StaticResource PrimaryButton}"
                        Margin="18,21,0,0"/>

            </Grid>
        </Border>

        <!-- STAT CARDS -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal"
                Margin="12,0,12,0"
                VerticalAlignment="Center">

                <controls:StatCard CardLabel="Tổng doanh thu" x:Name="cardTongDoanhThu"
                           Value="0 VNĐ"
                                   
                           SubLabel="Doanh thu trong ngày" 
                           ValueBrushKey="SuccessBrush"
                           Margin="0,0,30,0"/>

                <controls:StatCard CardLabel="Tổng hóa đơn" x:Name="cardTongHoaDon"
                           Value="0"
                           SubLabel="Hóa đơn đã thanh toán"
                           ValueBrushKey="TextPrimaryBrush"
                           Margin="0,0,30,0"/>

                <controls:StatCard CardLabel="Vé đã bán" x:Name="cardVeBan"
                           Value="0"
                           SubLabel="Số vé trong ngày"
                           ValueBrushKey="WarningBrush"
                           Margin="0,0,30,0"/>

                <controls:StatCard CardLabel="Doanh thu dịch vụ" x:Name="cardDichVu"
                           Value="0 VNĐ"
                           SubLabel="Combo, nước, bắp"
                           ValueBrushKey="DangerBrush"/>
            </StackPanel>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>

            <!-- DATAGRID -->
            <Border Grid.Column="0"
                    Background="#132231"
                    CornerRadius="10"
                    Padding="18"
                    Margin="0,0,18,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Chi tiết doanh thu theo rạp"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <DataGrid Grid.Row="1"
                              x:Name="dgBaoCao"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              Background="#132231"
                              Foreground="White"
                              RowBackground="#162A3A"
                              AlternatingRowBackground="#132231"
                              BorderThickness="0"
                              GridLinesVisibility="None">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Rạp"
                                                Binding="{Binding TenRap}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Doanh thu vé"
                            Binding="{Binding DoanhThuVe, StringFormat=N0}"
                            Width="150"/>

                            <DataGridTextColumn Header="Doanh thu dịch vụ"
                            Binding="{Binding DoanhThuDichVu, StringFormat=N0}"
                            Width="170"/>

                            <DataGridTextColumn Header="Tổng doanh thu"
                            Binding="{Binding TongDoanhThu, StringFormat=N0}"
                            Width="170"/>

                            <DataGridTextColumn Header="Đơn hàng"
                            Binding="{Binding SoDonHang}"
                            Width="100"/>
                            <DataGridTextColumn Header="Vé bán"
                            Binding="{Binding SoVeBan}"
                            Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- PIE CHART CARD -->
            <Border Grid.Column="1"
        Background="#132231"
        CornerRadius="20"
        Padding="18">

                <StackPanel>
                    <TextBlock Text="Cơ cấu doanh thu"
                   Foreground="White"
                   FontSize="18"
                   FontWeight="SemiBold"/>

                    <TextBlock Text="Doanh thu vé / dịch vụ"
                   Foreground="#8EA4B8"
                   FontSize="13"
                   Margin="0,4,0,18"/>

                    <lvc:PieChart x:Name="pieDoanhThu"
                      Height="230"
                      LegendPosition="Bottom"/>

                    <TextBlock x:Name="txtTyLeDoanhThu"
                   Text="Vé 0% • Dịch vụ 0%"
                   Foreground="#8EA4B8"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   Margin="0,14,0,0"/>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
