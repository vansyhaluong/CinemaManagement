<Window x:Class="Cinema.GUI.ThemNhanVien"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cinema.GUI"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="ThemNhanVien" Height="450" Width="500">
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="Employee Information"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,15"/>

        <!-- HO TEN -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Full Name" Foreground="White"/>
            <TextBox x:Name="txtHoTen"
                     Height="32"/>
        </StackPanel>

        <!-- SO DIEN THOAI -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Phone Number" Foreground="White"/>
            <TextBox x:Name="txtSoDienThoai"
                     Height="32"/>
        </StackPanel>

        <!-- MA TAI KHOAN -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Account ID" Foreground="White"/>
            <TextBox x:Name="txtMaTaiKhoan"
                     Height="32"/>
        </StackPanel>

        <!-- MA RAP -->
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Cinema Branch" Foreground="White"/>
            <ComboBox x:Name="cbRap"
                      Height="32">
                
            </ComboBox>
        </StackPanel>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Cancel"
                    Width="90"
                    Margin="0,0,10,0"
                    />

            <Button Content="Save"
                    Width="90"
                    Background="#22C55E"
                    Foreground="White"
                    BorderThickness="0"
                    x:Name="btnSave"
                    Click="btnSave_Click"
                    />

        </StackPanel>

    </Grid>
</Window>
