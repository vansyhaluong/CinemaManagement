<Window x:Class="Cinema.GUI.ThemNhanVien"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cinema.GUI"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Thêm nhân viên"
        Height="560"
        Width="520"
        ResizeMode="NoResize">

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Thêm nhân viên"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>

            <TextBlock Text="Tạo thông tin nhân viên và tài khoản đăng nhập"
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- HO TEN -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Họ tên"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="txtHoTen"
                     Height="34"/>
        </StackPanel>

        <!-- SO DIEN THOAI -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Số điện thoại"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="txtSoDienThoai"
                     Height="34"/>
        </StackPanel>

        <!-- RAP -->
        <StackPanel Grid.Row="3" Margin="0,0,0,18">
            <TextBlock Text="Rạp làm việc"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,5"/>
            <ComboBox x:Name="cbRap"
                      Height="34"
                      DisplayMemberPath="TenRap"
                      SelectedValuePath="MaRap"/>
        </StackPanel>

        <!-- ACCOUNT TITLE -->
        <TextBlock Grid.Row="4"
                   Text="Tài khoản đăng nhập"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,10"/>

        <!-- USERNAME -->
        <StackPanel Grid.Row="5" Margin="0,0,0,12">
            <TextBlock Text="Tên đăng nhập"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="txtTenDangNhap"
                     Height="34"/>
        </StackPanel>

        <!-- PASSWORD -->
        <StackPanel Grid.Row="6" Margin="0,0,0,18">
            <TextBlock Text="Mật khẩu"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtMatKhau"
                         Height="34"/>
        </StackPanel>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Hủy"
                    Width="90"
                    Height="34"
                    Margin="0,0,10,0"
                    Click="btnCancel_Click"/>

            <Button Content="Lưu"
                    Width="90"
                    Height="34"
                    Background="#22C55E"
                    Foreground="White"
                    BorderThickness="0"
                    x:Name="btnSave"
                    Click="btnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
