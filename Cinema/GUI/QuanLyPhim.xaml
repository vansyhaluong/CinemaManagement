<UserControl x:Class="Cinema.GUI.QuanLyPhim"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cinema.GUI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid Background="#0F172A">
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#111827" Padding="28,0">
                <DockPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                        <TextBlock Text="QUẢN LÝ PHIM" Foreground="White" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="Movie management dashboard" Foreground="#94A3B8" FontSize="13"/>
                    </StackPanel>
                    <Button Content="+ Thêm phim" Width="130" Height="42" DockPanel.Dock="Right"
                        HorizontalAlignment="Right" Margin="0,0,0,0"
                        Background="#2563EB" Foreground="White" BorderThickness="0"
                        FontWeight="SemiBold" Cursor="Hand"/>
                </DockPanel>
            </Border>
            <!-- Search -->
            <Border Grid.Row="1" Margin="24,20,24,14" Background="#111827" CornerRadius="18" Padding="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Height="40" FontSize="14" VerticalContentAlignment="Center"
                         Background="#1E293B" Foreground="White" BorderThickness="0"
                         Padding="14,0" Text="Tìm kiếm phim..."/>
                    <ComboBox Grid.Column="1" Margin="14,0,0,0" Height="40" SelectedIndex="0"
                          Background="#1E293B" Foreground="White" BorderThickness="0">
                        <ComboBoxItem Content="Tất cả thể loại"/>
                        <ComboBoxItem Content="Hành động"/>
                        <ComboBoxItem Content="Tình cảm"/>
                        <ComboBoxItem Content="Kinh dị"/>
                    </ComboBox>
                </Grid>
            </Border>
            <!-- Table -->
            <Border Grid.Row="2" Margin="24,0,24,24" Background="#111827" CornerRadius="18" Padding="16">
                <DataGrid AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      RowHeight="58"
                      CanUserAddRows="False"
                      Background="#111827"
                      BorderThickness="0"
                      Foreground="White"
                      AlternatingRowBackground="#0B1220"
                      RowBackground="#111827">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1E293B"/>
                            <Setter Property="Foreground" Value="#CBD5E1"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Height" Value="46"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding MaPhim}" Width="80"/>
                        <DataGridTextColumn Header="Tên phim" Binding="{Binding TenPhim}" Width="2*"/>
                        <DataGridTextColumn Header="Thể loại" Binding="{Binding TheLoai}" Width="*"/>
                        <DataGridTextColumn Header="Thời lượng" Binding="{Binding ThoiLuong}" Width="120"/>
                        <DataGridTextColumn Header="Khởi chiếu" Binding="{Binding KhoiChieu}" Width="140"/>
                        <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="130"/>
                        <DataGridTemplateColumn Header="Thao tác" Width="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="Sửa" Width="82" Height="34" Margin="0,0,8,0"
                                            Background="#F59E0B" Foreground="White" BorderThickness="0"
                                            Cursor="Hand"/>
                                        <Button Content="Xóa" Width="82" Height="34"
                                            Background="#EF4444" Foreground="White" BorderThickness="0"
                                            Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
