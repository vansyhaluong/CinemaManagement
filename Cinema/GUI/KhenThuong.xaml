<UserControl x:Class="Cinema.GUI.KhenThuong"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cinema.GUI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="Thưởng &amp; Kỷ luật"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="Bold"/>

                <TextBlock Text="Tự động tính thưởng/phạt theo dữ liệu chấm công trong tuần"
                           Foreground="#94A3B8"
                           FontSize="14"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>

        <!-- FILTER -->
        <Border Grid.Row="1"
                Background="#1E293B"
                CornerRadius="18"
                Padding="18"
                Margin="0,0,0,18">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="190"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Từ ngày"
                               Foreground="#CBD5E1"
                               FontWeight="SemiBold"/>
                    <DatePicker x:Name="dpTuNgay"
                                Height="38"
                                Margin="0,8,12,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Đến ngày"
                               Foreground="#CBD5E1"
                               FontWeight="SemiBold"/>
                    <DatePicker x:Name="dpDenNgay"
                                Height="38"
                                Margin="0,8,12,0"/>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           Text="Chọn khoảng 7 ngày để hệ thống tự kiểm tra đi trễ, vắng ca và chuyên cần."
                           Foreground="#94A3B8"
                           VerticalAlignment="Bottom"
                           Margin="0,0,20,8"/>

                <Button Grid.Column="3"
                        Content="🧮 Tính tự động"
                        Height="42"
                        VerticalAlignment="Bottom"
                        Background="#F97316"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnTinhTuDong_Click"/>
            </Grid>
        </Border>

        <!-- STATS -->
        <Grid Grid.Row="2" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Background="#172554" CornerRadius="18" Padding="18" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Tổng thưởng"
                               Foreground="#93C5FD"/>
                    <TextBlock x:Name="txtTongThuong"
                               Text="0đ"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#450A0A" CornerRadius="18" Padding="18" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Tổng phạt"
                               Foreground="#FCA5A5"/>
                    <TextBlock x:Name="txtTongPhat"
                               Text="0đ"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#064E3B" CornerRadius="18" Padding="18">
                <StackPanel>
                    <TextBlock Text="Nhân viên được thưởng"
                               Foreground="#6EE7B7"/>
                    <TextBlock x:Name="txtSoNhanVienThuong"
                               Text="0"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- KHEN THUONG -->
            <Border Background="#1E293B"
                    CornerRadius="18"
                    Padding="18"
                    Margin="0,0,10,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Danh sách khen thưởng"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>

                    <DataGrid x:Name="dgKhenThuong"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              Background="#1E293B"
                              Foreground="White"
                              RowBackground="#263449"
                              AlternatingRowBackground="#223047"
                              GridLinesVisibility="None"
                              BorderThickness="0">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nhân viên"
                                                Binding="{Binding HoTen}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Ngày"
                                                Binding="{Binding Ngay, StringFormat=dd/MM/yyyy}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Lý do"
                                                Binding="{Binding LyDo}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Tiền"
                                                Binding="{Binding SoTienThuong, StringFormat=N0}"
                                                Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- KY LUAT -->
            <Border Grid.Column="1"
                    Background="#1E293B"
                    CornerRadius="18"
                    Padding="18"
                    Margin="10,0,0,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Danh sách kỷ luật / phạt"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>

                    <DataGrid x:Name="dgKyLuat"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              Background="#1E293B"
                              Foreground="White"
                              RowBackground="#263449"
                              AlternatingRowBackground="#223047"
                              GridLinesVisibility="None"
                              BorderThickness="0">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nhân viên"
                                                Binding="{Binding HoTen}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Ngày"
                                                Binding="{Binding Ngay, StringFormat=dd/MM/yyyy}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Lý do"
                                                Binding="{Binding LyDo}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Tiền phạt"
                                                Binding="{Binding SoTienPhat, StringFormat=N0}"
                                                Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
