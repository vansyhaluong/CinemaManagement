      <TextObject Left="440" Top="0" Width="130" Height="28" Border.Lines="All" Text="[BaoCao.TienDichVu]" Format="Number" Format.UseLocale="true" HorzAlign="Right" VertAlign="Center" Font="Arial, 9pt"/>
