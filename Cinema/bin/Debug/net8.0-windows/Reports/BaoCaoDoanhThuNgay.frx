      <TextObject Left="0" Top="110" Width="170" Height="28" Text="Tổng doanh thu: [TongDoanhThu]" Font="Arial, 10pt, style=Bold" TextFill.Color="#16A34A"/>
      <TextObject Left="180" Top="110" Width="170" Height="28" Text="Tiền vé: [TongTienVe]" Font="Arial, 10pt"/>
      <TextObject Left="360" Top="110" Width="170" Height="28" Text="Dịch vụ: [TongTienDichVu]" Font="Arial, 10pt"/>
      <TextObject Left="540" Top="110" Width="178" Height="28" Text="Đơn hàng: [TongDonHang]" HorzAlign="Right" Font="Arial, 10pt"/>
    </ReportTitleBand>

    <PageHeaderBand Name="PageHeader1" Width="718.2" Height="30">
      <TextObject Left="0" Top="0" Width="120" Height="30" Border.Lines="All" Fill.Color="#0F1923" Text="Mã hóa đơn" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt, style=Bold" TextFill.Color="White"/>
      <TextObject Left="120" Top="0" Width="200" Height="30" Border.Lines="All" Fill.Color="#0F1923" Text="Khách hàng" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt, style=Bold" TextFill.Color="White"/>
      <TextObject Left="320" Top="0" Width="120" Height="30" Border.Lines="All" Fill.Color="#0F1923" Text="Tiền vé" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt, style=Bold" TextFill.Color="White"/>
