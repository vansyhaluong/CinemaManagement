<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="05/20/2026" ReportInfo.Modified="05/20/2026">
  <Dictionary>
    <BusinessObjectDataSource Name="BaoCao" ReferenceName="BaoCao" DataType="System.Int32" Enabled="true">
      <Column Name="MaHoaDon" DataType="System.String"/>
      <Column Name="KhachHang" DataType="System.String"/>
      <Column Name="TienVe" DataType="System.Decimal"/>
      <Column Name="TienDichVu" DataType="System.Decimal"/>
      <Column Name="TongTien" DataType="System.Decimal"/>
    </BusinessObjectDataSource>

    <Parameter Name="NgayBaoCao" DataType="System.String"/>
    <Parameter Name="TenRap" DataType="System.String"/>
    <Parameter Name="TongDoanhThu" DataType="System.String"/>
    <Parameter Name="TongTienVe" DataType="System.String"/>
    <Parameter Name="TongTienDichVu" DataType="System.String"/>
    <Parameter Name="TongDonHang" DataType="System.String"/>
  </Dictionary>

  <ReportPage Name="Page1" PaperWidth="210" PaperHeight="297" LeftMargin="10" RightMargin="10" TopMargin="10" BottomMargin="10">
    
    <ReportTitleBand Name="ReportTitle1" Width="718.2" Height="150">
      <TextObject Left="0" Top="0" Width="718" Height="28" Text="CINEMA MANAGEMENT SYSTEM" HorzAlign="Center" Font="Arial, 14pt, style=Bold" TextFill.Color="#0F1923"/>
      <TextObject Left="0" Top="32" Width="718" Height="34" Text="BÁO CÁO DOANH THU THEO NGÀY" HorzAlign="Center" Font="Arial, 18pt, style=Bold" TextFill.Color="#0EA5E9"/>

      <TextObject Left="0" Top="78" Width="359" Height="22" Text="Ngày báo cáo: [NgayBaoCao]" Font="Arial, 10pt"/>
