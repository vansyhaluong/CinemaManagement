    <DataBand Name="Data1" Width="718.2" Height="28" DataSource="BaoCao">
      <TextObject Left="0" Top="0" Width="120" Height="28" Border.Lines="All" Text="[BaoCao.MaHoaDon]" VertAlign="Center" Font="Arial, 9pt"/>
      <TextObject Left="120" Top="0" Width="200" Height="28" Border.Lines="All" Text="[BaoCao.KhachHang]" VertAlign="Center" Font="Arial, 9pt"/>
