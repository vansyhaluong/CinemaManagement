<!-- ============================================================
     STEP 5 — CONTROLS/NAVITEM.XAML
     A proper WPF UserControl for sidebar navigation.
     Uses DependencyProperties for Label, Icon, and IsActive.
     Participates in the theme toggle automatically because
     all colours are DynamicResource.

     KEY CONCEPT — DependencyProperty:
     WPF's binding system requires DependencyProperty (not a
     plain C# property) to enable XAML binding, data binding,
     animations, and style triggers on custom controls.
     ============================================================ -->
<UserControl x:Class="Cinema.Controls.NavItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="36" Cursor="Hand">

    <UserControl.Resources>
        <!-- Local converter-free approach: use triggers on the Border -->
    </UserControl.Resources>

    <Border x:Name="rootBorder"
            Background="Transparent"
            BorderThickness="2,0,0,0"
            BorderBrush="Transparent">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="38"/>  <!-- Icon -->
                <ColumnDefinition Width="*"/>   <!-- Label -->
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="iconText"
                       Grid.Column="0"
                       Text="{Binding Icon, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="14"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>

            <TextBlock x:Name="labelText"
                       Grid.Column="1"
                       Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontFamily="Segoe UI"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>

            <!-- Badge (shown when BadgeCount > 0, set via code-behind) -->
            <Border x:Name="badge"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    Background="{DynamicResource DangerBgBrush}"
                    CornerRadius="8"
                    Padding="6,2"
                    Visibility="Collapsed">
                <TextBlock x:Name="badgeText"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource DangerBrush}"/>
            </Border>
        </Grid>
    </Border>

    <!-- Triggers for IsActive and hover states -->
    <UserControl.Triggers>
        <!-- IsActive = true: accent left border + accent text -->
    </UserControl.Triggers>
</UserControl>
